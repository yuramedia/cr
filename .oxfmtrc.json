{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "useTabs": false,
    "tabWidth": 4,
    "printWidth": 120,
    "singleQuote": false,
    "jsxSingleQuote": false,
    "quoteProps": "as-needed",
    "trailingComma": "none",
    "semi": false,
    "arrowParens": "avoid",
    "bracketSameLine": false,
    "bracketSpacing": true,
    "singleAttributePerLine": false,
    "sortTailwindcss": {
        "stylesheet": "src/styles/global.css",
        "functions": ["cn", "cva"]
    },
    "ignorePatterns": [
        "node_modules/",
        "coverage/",
        ".pnpm-store/",
        "pnpm-lock.yaml",
        "package-lock.json",
        "yarn.lock",
        "dist/",
        ".astro/",
        "storage/",
        "backups/",
        ".env",
        ".env.*",
        "summaries/",
        "scratch/",
        "public/"
    ]
}
