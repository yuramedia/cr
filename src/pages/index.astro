              badge.className = 'text-[0.55rem] font-bold bg-accent-blue/10 border border-accent-blue/30 px-1 py-0.2 rounded text-accent-blue';
              item.classList.add('border-accent-blue/30', 'bg-accent-blue/3');
            }

            audiosRow.appendChild(badge);
          });
