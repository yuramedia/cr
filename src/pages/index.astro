---
// index.astro
import Layout from '../layouts/Layout.astro';
import TrackerHeader from '../components/TrackerHeader.astro';
import Filters from '../components/Filters.astro';
import EpisodeCard from '../components/EpisodeCard.astro';
---

<Layout title="Crunchyroll Tracker">
  <div class="flex flex-col min-h-screen bg-bg-primary text-white">
    <TrackerHeader />
    <Filters />

    <main class="flex-grow max-w-[1600px] w-full mx-auto px-4 sm:px-6 md:px-8 py-6">
      <!-- Loading State -->
      <div id="loading-state" class="flex flex-col items-center justify-center text-center p-6 sm:p-10 md:p-20 bg-bg-card border border-white/5 rounded-xl mt-4 min-h-[400px]">
        <div class="border-3 border-white/5 border-t-accent-orange rounded-full w-12 h-12 animate-spin mb-6"></div>
        <p class="text-text-secondary text-base sm:text-lg font-medium">Fetching latest episodes from Crunchyroll...</p>
      </div>

      <!-- Error State -->
      <div id="error-state" class="flex flex-col items-center justify-center text-center p-6 sm:p-10 md:p-20 bg-bg-card border border-white/5 rounded-xl mt-4 min-h-[400px] hidden">
        <div class="text-5xl mb-4">⚠️</div>
        <p class="text-text-secondary text-base sm:text-lg font-medium" id="error-message">Failed to load Crunchyroll data. Please check your connection or try again.</p>
        <button id="retry-btn" class="bg-accent-orange hover:bg-accent-orange-hover border-none text-white font-bold text-sm px-8 py-3 rounded-lg cursor-pointer mt-6 transition-colors duration-200 glowing-button">Retry Fetch</button>
      </div>

      <!-- Empty State -->
      <div id="empty-state" class="flex flex-col items-center justify-center text-center p-6 sm:p-10 md:p-20 bg-bg-card border border-white/5 rounded-xl mt-4 min-h-[400px] hidden">
        <div class="text-5xl mb-4">📺</div>
        <p class="text-text-secondary text-base sm:text-lg font-medium">No episodes found matching your filter criteria.</p>
      </div>

      <!-- Feed Container -->
      <div id="episodes-container" class="flex flex-col gap-12 hidden">
        <!-- Date Groups will be dynamically injected here -->
      </div>

      <!-- Infinite Scroll Sentinel -->
      <div id="infinite-scroll-sentinel" class="flex justify-center p-8 w-full hidden">
        <div class="flex items-center gap-3 bg-bg-card border border-white/5 rounded-full px-6 py-2.5 shadow-xl">
          <div class="animate-spin rounded-full h-4 w-4 border-2 border-t-accent-orange border-white/10"></div>
          <span class="text-text-secondary text-[0.7rem] font-extrabold tracking-widest uppercase">Loading older releases...</span>
        </div>
      </div>
    </main>
    
    <!-- Episode Card Template -->
    <EpisodeCard />

    <!-- Clipboard Toast Notification -->
    <div id="copied-toast" class="copied-toast">
      <span>✓</span> <span id="toast-text">Monospace ID copied to clipboard!</span>
    </div>
  </div>
</Layout>

<script>
  // Languages Constants mapping (seeded, updated dynamically)
  let LANG_MAP = {
    "en-US": "English",
    "ja-JP": "Japanese",
    "id-ID": "Indonesian",
    "ms-MY": "Malay",
    "ca-ES": "Catalan",
    "de-DE": "German",
    "es-LA": "Spanish (LA)",
    "es-ES": "Spanish (ES)",
    "es-419": "Spanish (LA)",
    "fr-FR": "French",
    "it-IT": "Italian",
    "pl-PL": "Polish",
    "pt-BR": "Portuguese (BR)",
    "pt-PT": "Portuguese",
    "vi-VN": "Viêtnamese",
    "tr-TR": "Turkish",
    "ru-RU": "Russian",
    "ar-SA": "Arabic",
    "hi-IN": "Hindi",
    "ta-IN": "Tamil",
    "te-IN": "Telugu",
    "zh-HK": "Cantonese",
    "zh-CN": "Mandarin",
    "zh-TW": "Mandarin (TW)",
    "ko-KR": "Korean",
    "th-TH": "Thai",
    "en-IN": "English (India)"
  };

  // Fetch dynamic timed text & audio languages from static.crunchyroll.com
  async function fetchLanguages() {
    try {
      const timedTextUrl = "https://proxy.cors.sh/https://static.crunchyroll.com/config/i18n/v3/timed_text_languages.json";
      const audioUrl = "https://proxy.cors.sh/https://static.crunchyroll.com/config/i18n/v3/audio_languages.json";

      const [timedTextRes, audioRes] = await Promise.all([
        fetch(timedTextUrl).then(res => (res.ok ? res.json() : null)).catch(() => null),
        fetch(audioUrl).then(res => (res.ok ? res.json() : null)).catch(() => null)
      ]);

      const merged = { ...LANG_MAP };

      if (timedTextRes && typeof timedTextRes === "object") {
        for (const [code, name] of Object.entries(timedTextRes)) {
          if (typeof name === "string") merged[code] = name;
        }
      }
      if (audioRes && typeof audioRes === "object") {
        for (const [code, name] of Object.entries(audioRes)) {
          if (typeof name === "string") merged[code] = name;
        }
      }

      LANG_MAP = merged;
    } catch (err) {
      console.warn("Failed to fetch static languages configs:", err);
    } finally {
      populateFilterOptions();
    }
  }

  // Populate Select options dynamically
  function populateFilterOptions() {
    if (!audioFilter || !subFilter) return;

    const currentAudio = audioFilter.value;
    const currentSub = subFilter.value;

    audioFilter.innerHTML = '<option value="all">All Audio</option>';
    subFilter.innerHTML = '<option value="all">All Subtitles</option>';

    const sortedLangs = Object.entries(LANG_MAP).sort((a, b) => a[1].localeCompare(b[1]));

    // Populate Audio Filter
    sortedLangs.forEach(([code, name]) => {
      const audioOpt = document.createElement('option');
      audioOpt.value = code;
      audioOpt.textContent = `${name} (${code.toUpperCase()})`;
      audioFilter.appendChild(audioOpt);
    });

    // Populate Subtitle Filter (Unique 2-letter uppercase codes)
    const seenSubs = new Set();
    sortedLangs.forEach(([code, name]) => {
      const subPrefix = code.split('-')[0].toUpperCase();
      const cleanLangName = name.split(' ')[0];

      if (!seenSubs.has(subPrefix)) {
        seenSubs.add(subPrefix);
        const subOpt = document.createElement('option');
        subOpt.value = subPrefix;
        subOpt.textContent = cleanLangName;
        subFilter.appendChild(subOpt);
      }
    });

    audioFilter.value = currentAudio;
    subFilter.value = currentSub;
  }

  // State
  let allEpisodes = [];
  let currentFilters = {
    search: '',
    audio: 'all',
    sub: 'all'
  };
  let isRefreshing = false;
  let currentAccessToken = null;
  let hasMore = true;
  let isLoadingMore = false;
  let searchTimeout = null;
  let currentView = 'feed';

  // Covers Cache State
  const COVERS_CACHE_KEY = "cr_series_covers_cache";
  let seriesCovers = {};

  // Constants
  const API_BASE = "https://beta-api.crunchyroll.com";
  const BASIC_AUTH = "cmpzMGx0eDBkYndrbGl3eGR6ZGY6NFY3cmYyMS1VRlhlWi01WEFkMFhfUVB3cjFndV9pMXM=";
  const USER_AGENT = "Crunchyroll/ANDROIDTV/3.65.0_22347 (Android 12; en-US; SHIELD Android TV Build/SR1A.211012.001)";
  
  // Storage Keys
  const CACHE_KEY = 'cr_episodes_cache';
  const CACHE_TIME_KEY = 'cr_episodes_cache_time';
  const LAST_SEEN_KEY = 'cr_last_seen_episode';

  // Covers Cache Helpers
  function loadCoversCache() {
    try {
      const cached = localStorage.getItem(COVERS_CACHE_KEY);
      if (cached) {
        seriesCovers = JSON.parse(cached);
      }
    } catch (e) {
      console.error("Failed to load covers cache:", e);
    }
  }

  function saveCoversCache() {
    try {
      localStorage.setItem(COVERS_CACHE_KEY, JSON.stringify(seriesCovers));
    } catch (e) {
      console.error("Failed to save covers cache:", e);
    }
  }

  async function getSeriesPoster(seriesId, accessToken) {
    if (seriesCovers[seriesId]) return seriesCovers[seriesId];

    try {
      const targetUrl = `${API_BASE}/content/v2/cms/series/${seriesId}`;
      const proxyUrl = `https://proxy.cors.sh/${targetUrl}`;

      const response = await fetch(proxyUrl, {
        method: "GET",
        headers: {
          Authorization: `Bearer ${accessToken}`,
          "User-Agent": USER_AGENT
        }
      });

      if (!response.ok) return null;
      const json = await response.json();
      if (json.data && json.data.length > 0) {
        const series = json.data[0];
        if (series.images && series.images.poster_tall) {
          const posters = series.images.poster_tall.flat();
          if (posters.length > 0) {
            const sorted = posters.toSorted((a, b) => b.width * b.height - a.width * a.height);
            // Select optimal size around 240px to 480px width for fast loading
            const optimal = sorted.find(p => p.width >= 240 && p.width <= 480) || sorted[sorted.length - 1];
            const posterUrl = optimal.source;
            
            seriesCovers[seriesId] = posterUrl;
            saveCoversCache();
            return posterUrl;
          }
        }
      }
    } catch (e) {
      console.error(`Failed to fetch series poster for ${seriesId}:`, e);
    }
    return null;
  }

  // DOM Elements (declared globally, initialized inside initApp)
  let headerFiltersBtn: HTMLElement | null = null;
  let filtersPanel: HTMLElement | null = null;
  let filtersArrow: HTMLElement | null = null;
  let refreshApiBtn: HTMLElement | null = null;
  let lastUpdateTimeSpan: HTMLElement | null = null;
  let searchInput: HTMLInputElement | null = null;
  let searchClearBtn: HTMLElement | null = null;
  let audioFilter: HTMLSelectElement | null = null;
  let subFilter: HTMLSelectElement | null = null;
  let resetFiltersBtn: HTMLElement | null = null;
  
  let loadingState: HTMLElement | null = null;
  let errorState: HTMLElement | null = null;
  let errorMessage: HTMLElement | null = null;
  let retryBtn: HTMLElement | null = null;
  let emptyState: HTMLElement | null = null;
  let episodesContainer: HTMLElement | null = null;
  let cardTemplate: HTMLTemplateElement | null = null;
  let copiedToast: HTMLElement | null = null;
  let toastText: HTMLElement | null = null;
  let sentinel: HTMLElement | null = null;
  let viewSelector: HTMLSelectElement | null = null;

  // Initialization
  document.addEventListener('DOMContentLoaded', () => {
    initApp();
  });

  async function initApp() {
    // Initialize DOM Elements after DOMContentLoaded
    headerFiltersBtn = document.getElementById('toggle-filters-btn');
    filtersPanel = document.getElementById('filters-panel');
    filtersArrow = document.getElementById('filters-arrow');
    refreshApiBtn = document.getElementById('refresh-api-btn');
    lastUpdateTimeSpan = document.getElementById('last-update-time');
    searchInput = document.getElementById('search-input') as HTMLInputElement;
    searchClearBtn = document.getElementById('search-clear-btn');
    audioFilter = document.getElementById('audio-filter') as HTMLSelectElement;
    subFilter = document.getElementById('sub-filter') as HTMLSelectElement;
    resetFiltersBtn = document.getElementById('reset-filters-btn');
    
    loadingState = document.getElementById('loading-state');
    errorState = document.getElementById('error-state');
    errorMessage = document.getElementById('error-message');
    retryBtn = document.getElementById('retry-btn');
    emptyState = document.getElementById('empty-state');
    episodesContainer = document.getElementById('episodes-container');
    cardTemplate = document.getElementById('episode-card-template') as HTMLTemplateElement;
    copiedToast = document.getElementById('copied-toast');
    toastText = document.getElementById('toast-text');
    sentinel = document.getElementById('infinite-scroll-sentinel');
    viewSelector = document.getElementById('view-selector') as HTMLSelectElement;

    // Fetch dynamic languages and populate selectors
    await fetchLanguages();

    setupEventListeners();
    loadCoversCache();
    loadCachedData();
    setupInfiniteScroll();
    
    // Always do a background refresh on start
    refreshData(false);
  }

  // Setup dynamic scroll listener using IntersectionObserver
  function setupInfiniteScroll() {
    if (!sentinel) return;

    const observer = new IntersectionObserver(async (entries) => {
      if (entries[0].isIntersecting && !isRefreshing && !isLoadingMore && hasMore) {
        await loadNextPage();
      }
    }, {
      rootMargin: '300px'
    });

    observer.observe(sentinel);
  }

  function setupEventListeners() {
    // Header actions
    if (headerFiltersBtn && filtersPanel) {
      headerFiltersBtn.addEventListener('click', () => {
        filtersPanel.classList.toggle('hidden');
        const isHidden = filtersPanel.classList.contains('hidden');
        if (filtersArrow) {
          filtersArrow.style.transform = isHidden ? 'rotate(0deg)' : 'rotate(180deg)';
        }
      });
    }

    if (refreshApiBtn) {
      refreshApiBtn.addEventListener('click', () => {
        if (!isRefreshing) refreshData(true);
      });
    }

    if (retryBtn) {
      retryBtn.addEventListener('click', () => {
        refreshData(true);
      });
    }

    // Filter controls
    if (searchInput) {
      searchInput.addEventListener('input', (e: any) => {
        const val = e.target.value;
        if (searchClearBtn) {
          searchClearBtn.style.display = val.trim() ? 'block' : 'none';
        }
        
        if (searchTimeout) clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => {
          currentFilters.search = val.toLowerCase().trim();
          renderFeed();
        }, 150);
      });
    }

    if (searchClearBtn && searchInput) {
      searchClearBtn.addEventListener('click', () => {
        searchInput.value = '';
        currentFilters.search = '';
        searchClearBtn.style.display = 'none';
        renderFeed();
      });
    }

    if (viewSelector) {
      viewSelector.addEventListener('change', (e: any) => {
        currentView = e.target.value;
        renderFeed();
      });
    }

    if (audioFilter) {
      audioFilter.addEventListener('change', (e: any) => {
        currentFilters.audio = e.target.value;
        renderFeed();
      });
    }

    if (subFilter) {
      subFilter.addEventListener('change', (e: any) => {
        currentFilters.sub = e.target.value;
        renderFeed();
      });
    }

    if (resetFiltersBtn) {
      resetFiltersBtn.addEventListener('click', () => {
        if (searchInput) searchInput.value = '';
        if (audioFilter) audioFilter.value = 'all';
        if (subFilter) subFilter.value = 'all';
        if (searchClearBtn) searchClearBtn.style.display = 'none';
        
        currentFilters = { search: '', audio: 'all', sub: 'all' };
        renderFeed();
      });
    }
  }

  // Access Token management helper
  async function getAccessToken() {
    if (currentAccessToken) return currentAccessToken;
    const tokenData = await fetchAnonymousToken();
    if (tokenData && tokenData.access_token) {
      currentAccessToken = tokenData.access_token;
      return currentAccessToken;
    }
    return null;
  }

  // Load from LocalStorage
  function loadCachedData() {
    try {
      const cached = localStorage.getItem(CACHE_KEY);
      const cacheTime = localStorage.getItem(CACHE_TIME_KEY);
      
      if (cached) {
        allEpisodes = JSON.parse(cached);
        if (cacheTime) {
          updateTimestamp(new Date(parseInt(cacheTime, 10)));
        }
        
        hasMore = allEpisodes.length >= 60;
        if (hasMore && sentinel) {
          sentinel.classList.remove('hidden');
        } else if (sentinel) {
          sentinel.classList.add('hidden');
        }

        loadingState.classList.add('hidden');
        renderFeed();
      }
    } catch (e) {
      console.error('Error loading cached data:', e);
    }
  }

  // Fetch New Data via CORS Proxy
  async function refreshData(isManual = false) {
    if (isRefreshing || isLoadingMore) return;
    
    isRefreshing = true;
    toggleLoadingUI(true);

    try {
      if (isManual) {
        currentAccessToken = null; // force token refresh
      }

      const token = await getAccessToken();
      if (!token) {
        throw new Error("Could not acquire Crunchyroll token.");
      }

      // Fetch Latest Episodes (Page 1 - offset 0)
      const episodes = await fetchCrunchyrollEpisodes(token, 0);
      if (!episodes || episodes.length === 0) {
        throw new Error("No episodes returned from Crunchyroll.");
      }

      const formatted = episodes.map(ep => formatEpisode(ep));

      allEpisodes = formatted;
      localStorage.setItem(CACHE_KEY, JSON.stringify(formatted));
      
      const now = Date.now();
      localStorage.setItem(CACHE_TIME_KEY, now.toString());
      updateTimestamp(new Date(now));

      hasMore = episodes.length >= 60;
      if (hasMore && sentinel) {
        sentinel.classList.remove('hidden');
      } else if (sentinel) {
        sentinel.classList.add('hidden');
      }

      errorState.classList.add('hidden');
      loadingState.classList.add('hidden');
      renderFeed();
    } catch (err: any) {
      console.error('Refresh API failed:', err);
      if (allEpisodes.length === 0) {
        if (errorMessage) errorMessage.textContent = err.message || "Failed to load Crunchyroll data.";
        errorState.classList.remove('hidden');
        loadingState.classList.add('hidden');
        episodesContainer.classList.add('hidden');
      } else {
        showToast("Error updating releases. Showing cached data.");
      }
    } finally {
      isRefreshing = false;
      toggleLoadingUI(false);
    }
  }

  // Fetch next page (older episodes)
  async function loadNextPage() {
    if (isRefreshing || isLoadingMore || !hasMore) return;

    isLoadingMore = true;
    if (sentinel) sentinel.classList.remove('hidden');

    try {
      const token = await getAccessToken();
      if (!token) throw new Error("Could not acquire token.");

      const offset = allEpisodes.length;
      const episodes = await fetchCrunchyrollEpisodes(token, offset);
      
      if (!episodes || episodes.length === 0) {
        hasMore = false;
        if (sentinel) sentinel.classList.add('hidden');
        return;
      }

      const formatted = episodes.map(ep => formatEpisode(ep));
      allEpisodes = [...allEpisodes, ...formatted];

      hasMore = episodes.length >= 60;
      if (!hasMore && sentinel) {
        sentinel.classList.add('hidden');
      }

      renderFeed();
    } catch (err) {
      console.error("Failed to load older episodes:", err);
      showToast("Failed to load older episodes.");
    } finally {
      isLoadingMore = false;
    }
  }

  function toggleLoadingUI(isLoading) {
    if (refreshApiBtn) {
      (refreshApiBtn as HTMLButtonElement).disabled = isLoading;
      refreshApiBtn.textContent = isLoading ? "Refreshing..." : "Refresh API";
    }
  }

  function updateTimestamp(date) {
    if (lastUpdateTimeSpan) {
      const timeStr = date.toTimeString().split(' ')[0];
      lastUpdateTimeSpan.textContent = timeStr;
    }
  }

  // Token authentication
  async function fetchAnonymousToken() {
    const body = new URLSearchParams();
    body.append("grant_type", "client_id");
    body.append("device_id", crypto.randomUUID());

    const targetUrl = `${API_BASE}/auth/v1/token`;
    const proxyUrl = `https://proxy.cors.sh/${targetUrl}`;

    const response = await fetch(proxyUrl, {
      method: "POST",
      headers: {
        Authorization: `Basic ${BASIC_AUTH}`,
        "Content-Type": "application/x-www-form-urlencoded; charset=utf-8",
        "User-Agent": USER_AGENT
      },
      body: body.toString()
    });

    if (!response.ok) return null;
    return await response.json();
  }

  // Fetch episodes with pagination support
  async function fetchCrunchyrollEpisodes(accessToken, start = 0) {
    const params = new URLSearchParams({
      start: String(start),
      n: "60",
      type: "episode",
      sort_by: "newly_added",
      force_locale: crypto.randomUUID()
    });

    const targetUrl = `${API_BASE}/content/v2/discover/browse?${params}`;
    const proxyUrl = `https://proxy.cors.sh/${targetUrl}`;

    const response = await fetch(proxyUrl, {
      method: "GET",
      headers: {
        Authorization: `Bearer ${accessToken}`,
        "User-Agent": USER_AGENT,
        "Cache-Control": "no-cache"
      }
    });

    if (!response.ok) return null;
    const json = await response.json();
    return json.data || [];
  }

  // RSS fetch deleted

  // Format single episode object
  function formatEpisode(ep) {
    const meta = ep.episode_metadata || {};
    
    // Series Title
    let seriesTitle = meta.series_title || "Unknown Series";
    
    // Add season name if applicable
    if (meta.season_title && meta.season_title.startsWith("Season") && !meta.season_title.includes("Season 1")) {
      seriesTitle += ` ${meta.season_title}`;
    }

    // Audio Language
    const audioLocale = meta.audio_locale || "";
    
    // Subtitles list
    const subtitleLocales = meta.subtitle_locales || [];
    
    // Format duration
    let duration = "0s";
    if (meta.duration_ms) {
      const totalSecs = Math.floor(meta.duration_ms / 1000);
      const mins = Math.floor(totalSecs / 60);
      const secs = totalSecs % 60;
      duration = mins > 0 ? `${mins}m ${secs}s` : `${secs}s`;
    }

    // Best thumbnail resolution
    let thumbnail = "";
    if (ep.images && ep.images.thumbnail) {
      const thumbs = ep.images.thumbnail.flat();
      if (thumbs.length > 0) {
        // Sort descending by resolution size
        const sorted = thumbs.toSorted((a, b) => b.width * b.height - a.width * a.height);
        thumbnail = sorted[0].source;
      }
    }

    // Best poster_tall resolution (vertical anime cover)
    let posterTall = "";
    if (ep.images && ep.images.poster_tall) {
      const posters = ep.images.poster_tall.flat();
      if (posters.length > 0) {
        // Sort descending by resolution size
        const sorted = posters.toSorted((a, b) => b.width * b.height - a.width * a.height);
        posterTall = sorted[0].source;
      }
    }

    // Extract publisher ID deleted

    // Release date
    const releasedAt = meta.premium_available_date || meta.availability_starts || ep.last_public;

    return {
      id: ep.id,
      title: ep.title || `Episode ${meta.episode_number || meta.episode || '-'}`,
      seriesTitle,
      description: ep.description || "No description available.",
      thumbnail,
      posterTall,
      episodeNumber: meta.episode || String(meta.episode_number || '--'),
      duration,
      audioLocale,
      subtitles: subtitleLocales,
      seriesId: meta.series_id || "Unknown",
      seasonId: meta.season_id || "Unknown",
      episodeId: ep.id,
      releasedAt
    };
  }

  // Render Card Feed
  function renderFeed() {
    if (!episodesContainer) return;

    // Filter Episodes
    const filtered = allEpisodes.filter(ep => {
      // 1. Text Search (debounced, accent-normalized, multi-word matching)
      if (currentFilters.search) {
        const queryTerms = currentFilters.search.split(/\s+/).filter(t => t.length > 0);
        
        if (queryTerms.length > 0) {
          const normalizeStr = (str) => {
            return str
              .toLowerCase()
              .normalize("NFD")
              .replace(/[\u0300-\u036f]/g, "");
          };

          const normalizedTitle = normalizeStr(ep.title);
          const normalizedSeries = normalizeStr(ep.seriesTitle);

          const matchesAll = queryTerms.every(term => {
            const normTerm = normalizeStr(term);
            return normalizedTitle.includes(normTerm) || normalizedSeries.includes(normTerm);
          });

          if (!matchesAll) return false;
        }
      }

      // 2. Audio Filter
      if (currentFilters.audio !== 'all') {
        if (ep.audioLocale !== currentFilters.audio) return false;
      }

      // 3. Subtitle Filter
      if (currentFilters.sub !== 'all') {
        const hasSub = ep.subtitles.some(sub => {
          return sub.toUpperCase().includes(currentFilters.sub.toUpperCase());
        });
        if (!hasSub) return false;
      }

      return true;
    });

    // Handle Empty State
    if (filtered.length === 0) {
      emptyState.classList.remove('hidden');
      episodesContainer.classList.add('hidden');
      if (sentinel) sentinel.classList.add('hidden');
      return;
    } else {
      emptyState.classList.add('hidden');
      episodesContainer.classList.remove('hidden');
      if (hasMore && sentinel) sentinel.classList.remove('hidden');
    }

    // Branch rendering by view mode
    if (currentView === 'feed') {
      renderFeedCard(filtered);
    } else if (currentView === 'compact') {
      renderFeedCompact(filtered);
    } else if (currentView === 'series') {
      renderFeedSeries(filtered);
    } else if (currentView === 'schedule') {
      renderFeedSchedule(filtered);
    }
  }

  // 1. View Mode: Card Feed
  function renderFeedCard(filtered) {
    // Group by Date
    const groups = {};
    filtered.forEach(ep => {
      const date = new Date(ep.releasedAt);
      const dateStr = date.toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' }).toUpperCase();
      
      if (!groups[dateStr]) {
        groups[dateStr] = [];
      }
      groups[dateStr].push(ep);
    });

    // Clear Container
    episodesContainer.innerHTML = '';

    // Get Active Watched Episode ID
    const watchedId = localStorage.getItem(LAST_SEEN_KEY);

    // Build DOM
    Object.keys(groups).forEach(dateStr => {
      const groupSection = document.createElement('section');
      groupSection.className = 'flex flex-col gap-6';

      const headerWrapper = document.createElement('div');
      headerWrapper.className = 'flex items-center justify-center w-full relative my-4';
      
      const line = document.createElement('div');
      line.className = 'absolute left-0 right-0 h-px bg-white/5 z-0';
      headerWrapper.appendChild(line);

      const header = document.createElement('div');
      header.className = 'bg-bg-primary text-accent-orange text-xs font-extrabold tracking-widest px-6 py-1.5 border border-white/5 rounded-full z-10 uppercase';
      header.textContent = dateStr;
      headerWrapper.appendChild(header);
      groupSection.appendChild(headerWrapper);

      const grid = document.createElement('div');
      grid.className = 'grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-4';

      groups[dateStr].forEach(ep => {
        const cardNode = createEpisodeCardNode(ep, watchedId);
        grid.appendChild(cardNode);
      });

      groupSection.appendChild(grid);
      episodesContainer.appendChild(groupSection);
    });
  }

  // 2. View Mode: Compact List
  function renderFeedCompact(filtered) {
    episodesContainer.innerHTML = '';
    
    const listWrapper = document.createElement('div');
    listWrapper.className = 'flex flex-col gap-3 w-full';

    const watchedId = localStorage.getItem(LAST_SEEN_KEY);

    filtered.forEach(ep => {
      const row = document.createElement('div');
      row.className = 'flex items-center gap-4 bg-bg-card border border-white/5 p-3 rounded-lg hover:border-white/10 transition-colors duration-200';

      const img = document.createElement('img');
      img.src = ep.thumbnail || '/placeholder.jpg';
      img.className = 'w-16 sm:w-20 aspect-video object-cover rounded shrink-0 bg-[#0b0b0d]';
      img.loading = 'lazy';
      row.appendChild(img);

      const textBlock = document.createElement('div');
      textBlock.className = 'flex-grow min-w-0';

      const seriesTitle = document.createElement('div');
      seriesTitle.className = 'text-accent-orange text-[0.65rem] font-bold uppercase truncate';
      seriesTitle.textContent = ep.seriesTitle;
      textBlock.appendChild(seriesTitle);

      const epTitle = document.createElement('div');
      epTitle.className = 'text-white text-xs sm:text-sm font-semibold truncate';
      epTitle.textContent = ep.title;
      textBlock.appendChild(epTitle);

      const metaStr = document.createElement('div');
      metaStr.className = 'text-text-muted text-[0.7rem] mt-0.5 uppercase';
      const date = new Date(ep.releasedAt);
      const timeStr = date.toLocaleDateString('en-US', { day: 'numeric', month: 'short' }) + `, ` + date.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false });
      metaStr.textContent = `EPISODE ${ep.episodeNumber} • ${timeStr}`;
      textBlock.appendChild(metaStr);

      row.appendChild(textBlock);

      const rightBlock = document.createElement('div');
      rightBlock.className = 'flex flex-col sm:flex-row items-end sm:items-center gap-2 shrink-0';

      const audioLabel = ep.audioLocale ? (LANG_MAP[ep.audioLocale] || ep.audioLocale) : '-';
      const audioBadge = document.createElement('div');
      audioBadge.className = 'text-[0.65rem] text-text-secondary bg-[#1c1c24] px-1.5 py-0.5 rounded border border-white/5 font-semibold uppercase';
      audioBadge.textContent = audioLabel;
      rightBlock.appendChild(audioBadge);

      const watchLink = document.createElement('a');
      watchLink.href = `https://www.crunchyroll.com/watch/${ep.id}`;
      watchLink.target = '_blank';
      watchLink.rel = 'noopener noreferrer';
      watchLink.className = 'bg-accent-orange hover:bg-accent-orange-hover text-white text-[0.7rem] font-bold px-3 py-1.5 rounded-lg transition-colors duration-200 uppercase';
      watchLink.textContent = 'Watch';
      
      watchLink.addEventListener('click', () => {
        handleWatchedToggle(ep.id);
      });

      rightBlock.appendChild(watchLink);
      row.appendChild(rightBlock);
      
      if (watchedId === ep.id) {
        row.classList.add('border-accent-blue/30', 'bg-accent-blue/3');
      }

      listWrapper.appendChild(row);
    });

    episodesContainer.appendChild(listWrapper);
  }

  // 3. View Mode: Grouped by Title
  function renderFeedSeries(filtered) {
    episodesContainer.innerHTML = '';
    
    const seriesGroups = {};
    filtered.forEach(ep => {
      if (!seriesGroups[ep.seriesTitle]) {
        seriesGroups[ep.seriesTitle] = {
          seriesTitle: ep.seriesTitle,
          seriesId: ep.seriesId,
          thumbnail: ep.thumbnail,
          description: ep.description,
          episodes: []
        };
      }
      seriesGroups[ep.seriesTitle].episodes.push(ep);
    });

    const grid = document.createElement('div');
    grid.className = 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6';

    const watchedId = localStorage.getItem(LAST_SEEN_KEY);

    Object.values(seriesGroups).forEach((group: any) => {
      const card = document.createElement('article');
      card.className = 'bg-bg-card border border-white/5 rounded-xl overflow-hidden flex flex-col p-4 gap-4 relative';

      // Blurred episode thumbnail backdrop
      if (group.thumbnail) {
        const bgGlow = document.createElement('div');
        bgGlow.className = 'absolute inset-0 z-0 opacity-[0.15] pointer-events-none select-none overflow-hidden';
        const bgImg = document.createElement('img');
        bgImg.src = group.thumbnail;
        bgImg.className = 'w-full h-full object-cover';
        bgGlow.appendChild(bgImg);
        card.appendChild(bgGlow);
      }

      const topSection = document.createElement('div');
      topSection.className = 'flex gap-3 items-start relative z-10';

      const img = document.createElement('img');
      img.className = 'w-16 sm:w-20 aspect-[2/3] object-cover rounded-md shrink-0 bg-[#0b0b0d] border border-white/10 shadow-md';
      img.loading = 'lazy';

      // Load cover from cache or fallback to thumbnail, then fetch in background
      const cachedPoster = seriesCovers[group.seriesId];
      if (cachedPoster) {
        img.src = cachedPoster;
      } else {
        img.src = group.thumbnail || '/placeholder.jpg';
        if (currentAccessToken && group.seriesId && group.seriesId !== 'Unknown') {
          getSeriesPoster(group.seriesId, currentAccessToken).then(posterUrl => {
            if (posterUrl) {
              img.src = posterUrl;
            }
          });
        }
      }
      topSection.appendChild(img);

      const textInfo = document.createElement('div');
      textInfo.className = 'min-w-0';

      const sTitle = document.createElement('h3');
      sTitle.className = 'text-white text-sm sm:text-base font-bold truncate';
      sTitle.textContent = group.seriesTitle;
      textInfo.appendChild(sTitle);

      const count = document.createElement('div');
      count.className = 'text-text-muted text-[0.7rem] font-semibold uppercase mt-0.5';
      count.textContent = `${group.episodes.length} Version(s) Released`;
      textInfo.appendChild(count);

      topSection.appendChild(textInfo);
      card.appendChild(topSection);

      const epList = document.createElement('div');
      epList.className = 'flex flex-col gap-2 border-t border-white/5 pt-3 relative z-10';

      group.episodes.forEach(ep => {
        const epRow = document.createElement('div');
        epRow.className = 'flex justify-between items-center bg-[#0b0b0d] p-2.5 rounded border border-white/3 gap-3 text-xs';

        const epMeta = document.createElement('div');
        epMeta.className = 'min-w-0';

        const epNumStr = document.createElement('span');
        epNumStr.className = 'text-accent-orange font-bold mr-1.5';
        epNumStr.textContent = `EP ${ep.episodeNumber}`;
        epMeta.appendChild(epNumStr);

        const audioCode = ep.audioLocale ? (LANG_MAP[ep.audioLocale] || ep.audioLocale) : '-';
        const audioBadge = document.createElement('span');
        audioBadge.className = 'text-white/60 font-semibold uppercase text-[0.65rem] bg-white/5 border border-white/10 px-1.5 py-0.5 rounded';
        audioBadge.textContent = audioCode;
        epMeta.appendChild(audioBadge);

        epRow.appendChild(epMeta);

        const watchBtn = document.createElement('a');
        watchBtn.href = `https://www.crunchyroll.com/watch/${ep.id}`;
        watchBtn.target = '_blank';
        watchBtn.rel = 'noopener noreferrer';
        watchBtn.className = 'text-accent-orange hover:text-accent-orange-hover font-bold text-xs uppercase transition-colors duration-200 shrink-0';
        watchBtn.textContent = 'Watch';
        
        watchBtn.addEventListener('click', () => {
          handleWatchedToggle(ep.id);
        });

        epRow.appendChild(watchBtn);

        if (watchedId === ep.id) {
          epRow.classList.add('border-accent-blue/30', 'bg-accent-blue/5');
          card.classList.add('border-accent-blue/30', 'shadow-[0_0_15px_rgba(0,132,255,0.1)]');
        }

        epList.appendChild(epRow);
      });

      card.appendChild(epList);
      grid.appendChild(card);
    });

    episodesContainer.appendChild(grid);
  }

  // 4. View Mode: Weekly Schedule
  function renderFeedSchedule(filtered) {
    episodesContainer.innerHTML = '';
    
    const days = ["SUNDAY", "MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY", "SATURDAY"];
    const scheduleGroups = {
      MONDAY: [], TUESDAY: [], WEDNESDAY: [], THURSDAY: [], FRIDAY: [], SATURDAY: [], SUNDAY: []
    };

    filtered.forEach(ep => {
      const date = new Date(ep.releasedAt);
      const dayName = days[date.getDay()];
      scheduleGroups[dayName].push(ep);
    });

    const scheduleGrid = document.createElement('div');
    scheduleGrid.className = 'grid grid-cols-1 md:grid-cols-7 gap-4 items-start w-full';

    const watchedId = localStorage.getItem(LAST_SEEN_KEY);

    Object.keys(scheduleGroups).forEach(day => {
      const col = document.createElement('div');
      col.className = 'flex flex-col gap-3 bg-bg-card border border-white/5 p-3.5 rounded-xl min-h-[150px] w-full';

      const header = document.createElement('h3');
      header.className = 'text-accent-orange text-[0.75rem] font-extrabold tracking-widest text-center border-b border-white/5 pb-2 uppercase';
      header.textContent = day;
      col.appendChild(header);

      const itemsList = document.createElement('div');
      itemsList.className = 'flex flex-col gap-2.5 w-full';

      const eps = scheduleGroups[day];
      
      const sortedEps = eps.sort((a, b) => {
        const dateA = new Date(a.releasedAt);
        const dateB = new Date(b.releasedAt);
        return dateA.getHours() * 60 + dateA.getMinutes() - (dateB.getHours() * 60 + dateB.getMinutes());
      });

      if (sortedEps.length === 0) {
        const empty = document.createElement('div');
        empty.className = 'text-text-muted text-[0.65rem] text-center italic py-4';
        empty.textContent = 'No releases';
        itemsList.appendChild(empty);
      } else {
        const uniqueShows = {};
        sortedEps.forEach(ep => {
          if (!uniqueShows[ep.seriesTitle]) {
            uniqueShows[ep.seriesTitle] = {
              seriesTitle: ep.seriesTitle,
              time: new Date(ep.releasedAt).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false }),
              thumbnail: ep.thumbnail,
              eps: []
            };
          }
          uniqueShows[ep.seriesTitle].eps.push(ep);
        });

        Object.values(uniqueShows).forEach((show: any) => {
          const item = document.createElement('div');
          item.className = 'bg-[#0b0b0d] border border-white/3 p-2 rounded flex flex-col gap-1.5 text-[0.725rem] min-w-0';

          if (show.thumbnail) {
            const thumbWrapper = document.createElement('div');
            thumbWrapper.className = 'w-full aspect-video rounded overflow-hidden bg-[#131317] shrink-0 mb-0.5';
            const img = document.createElement('img');
            img.src = show.thumbnail;
            img.className = 'w-full h-full object-cover';
            img.loading = 'lazy';
            thumbWrapper.appendChild(img);
            item.appendChild(thumbWrapper);
          }

          const timeStr = document.createElement('div');
          timeStr.className = 'text-accent-orange font-bold text-[0.65rem]';
          timeStr.textContent = show.time;
          item.appendChild(timeStr);

          const title = document.createElement('div');
          title.className = 'text-white font-semibold truncate';
          title.textContent = show.seriesTitle;
          title.title = show.seriesTitle;
          item.appendChild(title);

          const audiosRow = document.createElement('div');
          audiosRow.className = 'flex gap-1 flex-wrap mt-0.5';
          show.eps.forEach(ep => {
            const shortLang = ep.audioLocale ? ep.audioLocale.split('-')[0].toUpperCase() : 'RAW';
            const badge = document.createElement('a');
            badge.href = `https://www.crunchyroll.com/watch/${ep.id}`;
            badge.target = '_blank';
            badge.rel = 'noopener noreferrer';
            badge.className = 'text-[0.55rem] font-bold bg-white/5 border border-white/10 px-1 py-0.2 rounded hover:bg-accent-orange/10 hover:border-accent-orange/30 text-text-secondary hover:text-accent-orange transition-colors';
            badge.textContent = shortLang;
            
            badge.addEventListener('click', () => {
              handleWatchedToggle(ep.id);
            });

            if (watchedId === ep.id) {
              badge.className = 'text-[0.55rem] font-bold bg-accent-blue/10 border border-accent-blue/30 px-1 py-0.2 rounded text-accent-blue';
              item.classList.add('border-accent-blue/30', 'bg-accent-blue/3');
            }

            audiosRow.appendChild(badge);
          });
          item.appendChild(audiosRow);

          itemsList.appendChild(item);
        });
      }

      col.appendChild(itemsList);
      scheduleGrid.appendChild(col);
    });

    episodesContainer.appendChild(scheduleGrid);
  }

  // Create DOM Node from Template
  function createEpisodeCardNode(ep, watchedId) {
    const clone = cardTemplate.content.cloneNode(true) as DocumentFragment;
    const card = clone.querySelector('.episode-card') as HTMLElement;
    
    // Image and badge
    const img = card.querySelector('.card-image') as HTMLImageElement;
    img.src = ep.thumbnail || '/placeholder.jpg';
    img.alt = ep.seriesTitle;

    const badge = card.querySelector('.episode-badge') as HTMLElement;
    if (badge) {
      badge.textContent = `EPISODE ${ep.episodeNumber}`;
    }

    // Titles and description
    card.querySelector('.series-title').textContent = ep.seriesTitle;
    
    const epTitle = card.querySelector('.episode-title') as HTMLElement;
    epTitle.textContent = ep.title;
    epTitle.title = ep.title;

    const desc = card.querySelector('.episode-description') as HTMLElement;
    desc.textContent = ep.description;
    desc.title = ep.description;

    // Metadata details
    const date = new Date(ep.releasedAt);
    const dateFormatted = date.toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' }) + `, ` + date.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false });
    card.querySelector('.val-release').textContent = dateFormatted;

    // Audio Locale badge
    const audioLabel = ep.audioLocale ? (LANG_MAP[ep.audioLocale] || ep.audioLocale) : '-';
    const audioSpan = document.createElement('span');
    audioSpan.className = 'bg-accent-orange/12 border border-accent-orange/20 text-accent-orange px-1.5 py-0.5 rounded font-bold text-[0.725rem]';
    audioSpan.textContent = audioLabel;
    card.querySelector('.val-audio').appendChild(audioSpan);

    // Subtitles locales list
    const subsContainer = card.querySelector('.val-subs') as HTMLElement;
    if (ep.subtitles && ep.subtitles.length > 0) {
      ep.subtitles.forEach(sub => {
        const cleanName = LANG_MAP[sub] || sub;
        const subItem = document.createElement('bidi-item');
        subItem.textContent = cleanName;
        subsContainer.appendChild(subItem);
      });
    } else {
      subsContainer.textContent = '-';
    }

    // IDs copy buttons
    setupCopyBtn(card.querySelector('.val-series-id'), ep.seriesId);
    setupCopyBtn(card.querySelector('.val-season-id'), ep.seasonId);
    setupCopyBtn(card.querySelector('.val-episode-id'), ep.episodeId);

    // Watched State
    const actionBtn = card.querySelector('.seen-action-btn') as HTMLAnchorElement;
    actionBtn.href = `https://www.crunchyroll.com/watch/${ep.id}`;
    
    if (watchedId === ep.id) {
      card.classList.add('watched');
      actionBtn.textContent = 'Watch Episode (Last Seen)';
    } else {
      actionBtn.textContent = 'Watch Episode';
    }

    // Seen Action handler
    actionBtn.addEventListener('click', () => {
      handleWatchedToggle(ep.id);
    });

    return card;
  }

  function setupCopyBtn(btn, val) {
    btn.textContent = val;
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      copyToClipboard(val);
    });
  }

  // Copy Clipboard Helper
  function copyToClipboard(text) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(text).then(() => {
        showToast(`Copied ID: ${text}`);
      }).catch(err => {
        console.error('Clipboard copy failed:', err);
      });
    } else {
      // Fallback
      const textArea = document.createElement("textarea");
      textArea.value = text;
      textArea.style.position = "fixed";
      document.body.appendChild(textArea);
      textArea.focus();
      textArea.select();
      try {
        document.execCommand('copy');
        showToast(`Copied ID: ${text}`);
      } catch (err) {
        console.error('Fallback copy failed:', err);
      }
      document.body.removeChild(textArea);
    }
  }

  // Show Toast Alert
  function showToast(message) {
    if (copiedToast && toastText) {
      toastText.textContent = ` ${message}`;
      copiedToast.classList.add('show');
      setTimeout(() => {
        copiedToast.classList.remove('show');
      }, 2500);
    }
  }

  // Handle Mark as Last Seen Click
  function handleWatchedToggle(episodeId) {
    const currentWatched = localStorage.getItem(LAST_SEEN_KEY);
    
    if (currentWatched === episodeId) {
      // Unmark if clicked currently watched
      localStorage.removeItem(LAST_SEEN_KEY);
    } else {
      // Set new watched episode
      localStorage.setItem(LAST_SEEN_KEY, episodeId);
    }

    // Rerender to apply watched visual updates
    renderFeed();
  }
</script>
