        const uniqueShows = {};
        sortedEps.forEach(ep => {
          if (!uniqueShows[ep.seriesTitle]) {
            uniqueShows[ep.seriesTitle] = {
              seriesTitle: ep.seriesTitle,
              time: new Date(ep.releasedAt).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false }),
              thumbnail: ep.thumbnail,
              eps: []
            };
