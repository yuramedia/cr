      const header = document.createElement('h3');
      header.className = 'text-accent-orange text-[0.75rem] font-extrabold tracking-widest text-center border-b border-white/5 pb-2 uppercase';
      header.textContent = day;
      col.appendChild(header);

      const itemsList = document.createElement('div');
      itemsList.className = 'flex flex-col gap-2.5 w-full';

      const eps = scheduleGroups[day];
      
      const sortedEps = eps.sort((a, b) => {
        const dateA = new Date(a.releasedAt);
        const dateB = new Date(b.releasedAt);
        return dateA.getHours() * 60 + dateA.getMinutes() - (dateB.getHours() * 60 + dateB.getMinutes());
      });

      if (sortedEps.length === 0) {
        const empty = document.createElement('div');
        empty.className = 'text-text-muted text-[0.65rem] text-center italic py-4';
        empty.textContent = 'No releases';
        itemsList.appendChild(empty);
