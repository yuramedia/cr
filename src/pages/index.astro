---
// index.astro
import Layout from '../layouts/Layout.astro';
import TrackerHeader from '../components/TrackerHeader.astro';
import Filters from '../components/Filters.astro';
import EpisodeCard from '../components/EpisodeCard.astro';
---

<Layout title="Crunchyroll Tracker">
  <div class="flex flex-col min-h-screen bg-bg-primary text-white">
    <TrackerHeader />
    <Filters />

    <main class="flex-grow max-w-[1600px] w-full mx-auto px-4 sm:px-6 md:px-8 py-6">
      <!-- Loading State -->
      <div id="loading-state" class="flex flex-col items-center justify-center text-center p-6 sm:p-10 md:p-20 bg-bg-card border border-white/5 rounded-xl mt-4 min-h-[400px]">
        <div class="border-3 border-white/5 border-t-accent-orange rounded-full w-12 h-12 animate-spin mb-6"></div>
        <p class="text-text-secondary text-base sm:text-lg font-medium">Fetching latest episodes from Crunchyroll...</p>
      </div>

      <!-- Error State -->
      <div id="error-state" class="flex flex-col items-center justify-center text-center p-6 sm:p-10 md:p-20 bg-bg-card border border-white/5 rounded-xl mt-4 min-h-[400px] hidden">
        <div class="text-5xl mb-4">⚠️</div>
        <p class="text-text-secondary text-base sm:text-lg font-medium" id="error-message">Failed to load Crunchyroll data. Please check your connection or try again.</p>
        <button id="retry-btn" class="bg-accent-orange hover:bg-accent-orange-hover border-none text-white font-bold text-sm px-8 py-3 rounded-lg cursor-pointer mt-6 transition-colors duration-200 glowing-button">Retry Fetch</button>
      </div>

      <!-- Empty State -->
      <div id="empty-state" class="flex flex-col items-center justify-center text-center p-6 sm:p-10 md:p-20 bg-bg-card border border-white/5 rounded-xl mt-4 min-h-[400px] hidden">
        <div class="text-5xl mb-4">📺</div>
        <p class="text-text-secondary text-base sm:text-lg font-medium">No episodes found matching your filter criteria.</p>
      </div>

      <!-- Feed Container -->
      <div id="episodes-container" class="flex flex-col gap-12 hidden">
        <!-- Date Groups will be dynamically injected here -->
      </div>

      <!-- Infinite Scroll Sentinel -->
      <div id="infinite-scroll-sentinel" class="flex justify-center p-8 w-full hidden">
        <div class="flex items-center gap-3 bg-bg-card border border-white/5 rounded-full px-6 py-2.5 shadow-xl">
          <div class="animate-spin rounded-full h-4 w-4 border-2 border-t-accent-orange border-white/10"></div>
          <span class="text-text-secondary text-[0.7rem] font-extrabold tracking-widest uppercase">Loading older releases...</span>
        </div>
      </div>

      <!-- Detail Page Container -->
      <div id="detail-container" class="mt-4 hidden">
        <!-- Back Button -->
        <button id="detail-back-btn" class="flex items-center gap-2 text-text-secondary hover:text-accent-orange font-bold text-[0.75rem] tracking-wider uppercase bg-bg-card border border-white/5 px-4 py-2.5 rounded-lg cursor-pointer transition-colors duration-200 mb-6 select-none">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to list
        </button>

        <!-- Detail Loader -->
        <div id="detail-loader" class="flex flex-col items-center justify-center py-20 bg-bg-card border border-white/5 rounded-xl min-h-[400px]">
          <div class="border-3 border-white/5 border-t-accent-orange rounded-full w-12 h-12 animate-spin mb-6"></div>
          <p class="text-text-secondary text-base sm:text-lg font-medium">Loading details...</p>
        </div>

        <!-- Detail Content -->
        <div id="detail-content" class="hidden">
          <!-- Dynamically injected detail markup -->
        </div>
      </div>
    </main>
    
    <!-- Episode Card Template -->
    <EpisodeCard />

    <!-- Clipboard Toast Notification -->
    <div id="copied-toast" class="copied-toast">
      <span>✓</span> <span id="toast-text">Monospace ID copied to clipboard!</span>
    </div>

    <!-- New Episodes Toast Notification -->
    <div id="new-episodes-toast" class="fixed top-20 left-1/2 -translate-x-1/2 z-50 bg-accent-orange hover:bg-accent-orange-hover text-white text-xs sm:text-sm font-bold px-5 py-3 rounded-full shadow-2xl cursor-pointer transition-all duration-300 transform -translate-y-4 opacity-0 pointer-events-none flex items-center gap-2 border border-white/10 select-none">
      <svg class="w-4 h-4 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" />
      </svg>
      <span>New releases available! Click to load</span>
    </div>
  </div>
</Layout>

<script>
  import { LANG_MAP, CACHE_LIFETIME, CACHE_TIME_KEY, CACHE_KEY, LAST_SEEN_KEY, MAX_CACHED_EPISODES } from "../scripts/constants";
  import { getProxyUrl, getAccessToken as getAccessTokenApi, fetchCrunchyrollEpisodes, fetchSeriesPoster as fetchSeriesPosterApi, fetchLanguagesConfig, fetchObject, fetchSeriesSeasons, fetchSeasonEpisodes } from "../scripts/api";
  import { loadSpreadsheetData, populatePipelineForCard, updateVisibleCardsPipeline, sheetDataMap, normalizeTitleForSheet } from "../scripts/sheet";
  import { loadEpisodesCache, saveEpisodesCache as saveEpisodesCacheToStore, loadCoversCache, saveCoversCache as saveCoversCacheToStore, clearCache } from "../scripts/cache";

  // Active languages configuration mapping (seeded, updated dynamically)
  let activeLangMap = { ...LANG_MAP };

  // Fetch dynamic timed text & audio languages from static.crunchyroll.com
  async function fetchLanguages() {
    try {
      const config = await fetchLanguagesConfig();
      if (!config) return;

      const merged = { ...activeLangMap };
      if (config.timedText && typeof config.timedText === "object") {
        for (const [code, name] of Object.entries(config.timedText)) {
          if (typeof name === "string") merged[code] = name;
        }
      }
      if (config.audio && typeof config.audio === "object") {
        for (const [code, name] of Object.entries(config.audio)) {
          if (typeof name === "string") merged[code] = name;
        }
      }

      activeLangMap = merged;
    } catch (err) {
      console.warn("Failed to fetch static languages configs:", err);
    } finally {
      populateFilterOptions();
    }
  }

  // Populate Select options dynamically
  function populateFilterOptions() {
    if (!audioFilter || !subFilter) return;

    const currentAudio = audioFilter.value;
    const currentSub = subFilter.value;

    audioFilter.innerHTML = '<option value="all">All Audio</option>';
    subFilter.innerHTML = '<option value="all">All Subtitles</option>';

    const sortedLangs = Object.entries(activeLangMap).sort((a, b) => a[1].localeCompare(b[1]));

    // Populate Audio Filter
    sortedLangs.forEach(([code, name]) => {
      const audioOpt = document.createElement('option');
      audioOpt.value = code;
      audioOpt.textContent = `${name} (${code.toUpperCase()})`;
      audioFilter.appendChild(audioOpt);
    });

    // Populate Subtitle Filter (Unique 2-letter uppercase codes)
    const seenSubs = new Set();
    sortedLangs.forEach(([code, name]) => {
      const subPrefix = code.split('-')[0].toUpperCase();
      let cleanLangName = name.split(' ')[0];
      if (cleanLangName === "Bahasa" && name.split(' ').length > 1) {
        cleanLangName = name;
      }

      if (!seenSubs.has(subPrefix)) {
        seenSubs.add(subPrefix);
        const subOpt = document.createElement('option');
        subOpt.value = subPrefix;
        subOpt.textContent = cleanLangName;
        subFilter.appendChild(subOpt);
      }
    });

    audioFilter.value = currentAudio;
    subFilter.value = currentSub;
  }

  // State
  let allEpisodes = [];
  let currentFilters = {
    search: '',
    audio: 'all',
    sub: 'all'
  };
  let isRefreshing = false;
  let currentAccessToken = null;
  let hasMore = true;
  let isLoadingMore = false;
  let searchTimeout = null;
  let currentView = 'feed';
  let pollingInterval = null;
  let useProxyCheckbox: HTMLInputElement | null = null;

  // Filter memoization
  let filterCacheKey = '';
  let filteredCache = null;

  // Render tracking for incremental updates
  let lastRenderedView = '';
  let lastRenderedFilterKey = '';
  const renderedEpisodeIds = new Set();

  // Covers Cache State
  let seriesCovers = loadCoversCache();

  // Poster fetch queue (dedupe + concurrency limit)
  const posterInflight = new Map();
  const posterQueue = [];
  let posterActiveCount = 0;
  const POSTER_CONCURRENCY = 4;
  const PLACEHOLDER_IMG = '';

  function invalidateFilterCache() {
    filterCacheKey = '';
    filteredCache = null;
  }

  function normalizeStr(str) {
    return str
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "");
  }

  function episodePassesFilter(ep) {
    if (currentFilters.search) {
      const queryTerms = currentFilters.search.split(/\s+/).filter(t => t.length > 0);
      if (queryTerms.length > 0) {
        const normalizedTitle = normalizeStr(ep.title);
        const normalizedSeries = normalizeStr(ep.seriesTitle);
        const matchesAll = queryTerms.every(term => {
          const normTerm = normalizeStr(term);
          return normalizedTitle.includes(normTerm) || normalizedSeries.includes(normTerm);
        });
        if (!matchesAll) return false;
      }
    }

    if (currentFilters.audio !== 'all' && ep.audioLocale !== currentFilters.audio) {
      return false;
    }

    if (currentFilters.sub !== 'all') {
      const subUpper = currentFilters.sub.toUpperCase();
      const hasSub = ep.subtitles.some(sub => sub.toUpperCase().includes(subUpper));
      if (!hasSub) return false;
    }

    return true;
  }

  function getFilteredEpisodes() {
    const key = `${currentFilters.search}|${currentFilters.audio}|${currentFilters.sub}`;
    if (key === filterCacheKey && filteredCache) return filteredCache;

    filteredCache = allEpisodes.filter(episodePassesFilter);
    filterCacheKey = key;
    return filteredCache;
  }

  function saveEpisodesCache() {
    saveEpisodesCacheToStore(allEpisodes);
  }

  async function fetchSeriesPoster(seriesId, accessToken) {
    const posterUrl = await fetchSeriesPosterApi(seriesId, accessToken);
    if (posterUrl) {
      seriesCovers[seriesId] = posterUrl;
      saveCoversCacheToStore(seriesCovers);
      return posterUrl;
    }
    return null;
  }

  function processPosterQueue() {
    while (posterActiveCount < POSTER_CONCURRENCY && posterQueue.length > 0) {
      const job = posterQueue.shift();
      posterActiveCount++;

      fetchSeriesPoster(job.seriesId, job.accessToken)
        .then(job.resolve)
        .catch(() => job.resolve(null))
        .finally(() => {
          posterActiveCount--;
          posterInflight.delete(job.seriesId);
          processPosterQueue();
        });
    }
  }

  async function getSeriesPoster(seriesId, accessToken) {
    if (seriesCovers[seriesId]) return seriesCovers[seriesId];
    if (posterInflight.has(seriesId)) return posterInflight.get(seriesId);

    const promise = new Promise((resolve) => {
      posterQueue.push({ seriesId, accessToken, resolve });
      processPosterQueue();
    });

    posterInflight.set(seriesId, promise);
    return promise;
  }

  // DOM Elements (declared globally, initialized inside initApp)
  let headerFiltersBtn: HTMLElement | null = null;
  let filtersPanel: HTMLElement | null = null;
  let filtersArrow: HTMLElement | null = null;
  let refreshApiBtn: HTMLElement | null = null;
  let lastUpdateTimeSpan: HTMLElement | null = null;
  let searchInput: HTMLInputElement | null = null;
  let searchClearBtn: HTMLElement | null = null;
  let audioFilter: HTMLSelectElement | null = null;
  let subFilter: HTMLSelectElement | null = null;
  let resetFiltersBtn: HTMLElement | null = null;
  
  let loadingState: HTMLElement | null = null;
  let errorState: HTMLElement | null = null;
  let errorMessage: HTMLElement | null = null;
  let retryBtn: HTMLElement | null = null;
  let emptyState: HTMLElement | null = null;
  let episodesContainer: HTMLElement | null = null;
  let cardTemplate: HTMLTemplateElement | null = null;
  let copiedToast: HTMLElement | null = null;
  let toastText: HTMLElement | null = null;
  let sentinel: HTMLElement | null = null;
  let viewSelector: HTMLSelectElement | null = null;
  let newEpisodesToast: HTMLElement | null = null;
  let pendingEpisodes = null;

  // New episodes notification helpers
  function showNewEpisodesToast() {
    if (!newEpisodesToast) return;
    newEpisodesToast.classList.remove('opacity-0', 'pointer-events-none', '-translate-y-4');
    newEpisodesToast.classList.add('opacity-100', 'translate-y-0');
  }

  function hideNewEpisodesToast() {
    if (!newEpisodesToast) return;
    newEpisodesToast.classList.remove('opacity-100', 'translate-y-0');
    newEpisodesToast.classList.add('opacity-0', 'pointer-events-none', '-translate-y-4');
  }

  // Auto-polling helpers
  function startAutoPolling() {
    if (pollingInterval) clearInterval(pollingInterval);

    pollingInterval = setInterval(async () => {
      if (document.visibilityState === 'visible' && !isRefreshing && !isLoadingMore) {
        console.log("Auto-polling triggered background refresh...");
        await refreshData(false);
      }
    }, 60 * 1000); // 1 minute in ms
  }

  // Initialization
  document.addEventListener('DOMContentLoaded', () => {
    initApp();
  });

  async function initApp() {
    // Initialize DOM Elements after DOMContentLoaded
    headerFiltersBtn = document.getElementById('toggle-filters-btn');
    filtersPanel = document.getElementById('filters-panel');
    filtersArrow = document.getElementById('filters-arrow');
    refreshApiBtn = document.getElementById('refresh-api-btn');
    lastUpdateTimeSpan = document.getElementById('last-update-time');
    searchInput = document.getElementById('search-input') as HTMLInputElement;
    searchClearBtn = document.getElementById('search-clear-btn');
    audioFilter = document.getElementById('audio-filter') as HTMLSelectElement;
    subFilter = document.getElementById('sub-filter') as HTMLSelectElement;
    resetFiltersBtn = document.getElementById('reset-filters-btn');
    
    loadingState = document.getElementById('loading-state');
    errorState = document.getElementById('error-state');
    errorMessage = document.getElementById('error-message');
    retryBtn = document.getElementById('retry-btn');
    emptyState = document.getElementById('empty-state');
    episodesContainer = document.getElementById('episodes-container');
    cardTemplate = document.getElementById('episode-card-template') as HTMLTemplateElement;
    copiedToast = document.getElementById('copied-toast');
    toastText = document.getElementById('toast-text');
    sentinel = document.getElementById('infinite-scroll-sentinel');
    viewSelector = document.getElementById('view-selector') as HTMLSelectElement;
    useProxyCheckbox = document.getElementById('use-proxy-checkbox') as HTMLInputElement;
    newEpisodesToast = document.getElementById('new-episodes-toast');

    // Load initial checkbox state
    if (useProxyCheckbox) {
      useProxyCheckbox.checked = localStorage.getItem('cr_use_cors_proxy') !== 'false';
    }

    // Fetch dynamic languages and populate selectors
    await fetchLanguages();

    setupEventListeners();
    setupFeedDelegation();
    loadCachedData();
    loadSpreadsheetData();
    setupInfiniteScroll();
    
    // Only trigger a background refresh on start if cache is older than 1 minute
    const cacheTime = localStorage.getItem(CACHE_TIME_KEY);
    const now = Date.now();
    const CACHE_LIFETIME = 1 * 60 * 1000; // 1 minute in ms

    if (!cacheTime || (now - parseInt(cacheTime, 10)) > CACHE_LIFETIME) {
      refreshData(false);
    }

    // Start auto polling (1 minute interval) when tab is active
    startAutoPolling();

    // Pause/Resume polling on visibility changes to save CPU/battery
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') {
        const cacheTime = localStorage.getItem(CACHE_TIME_KEY);
        const now = Date.now();
        if (!cacheTime || (now - parseInt(cacheTime, 10)) > CACHE_LIFETIME) {
          refreshData(false);
        }
        startAutoPolling();
      } else {
        if (pollingInterval) {
          clearInterval(pollingInterval);
          pollingInterval = null;
        }
      }
    });

    // Routing listeners
    window.addEventListener('hashchange', handleRoute);
    
    // Bind detail page back button
    const detailBackBtn = document.getElementById('detail-back-btn');
    if (detailBackBtn) {
      detailBackBtn.addEventListener('click', () => {
        window.location.hash = '#/';
      });
    }

    // Handle initial route
    await handleRoute();
  }

  // Setup dynamic scroll listener using IntersectionObserver
  function setupInfiniteScroll() {
    if (!sentinel) return;

    const observer = new IntersectionObserver(async (entries) => {
      if (entries[0].isIntersecting && !isRefreshing && !isLoadingMore && hasMore) {
        await loadNextPage();
      }
    }, {
      rootMargin: '300px'
    });

    observer.observe(sentinel);
  }

  function setupEventListeners() {
    // Header actions
    if (headerFiltersBtn && filtersPanel) {
      headerFiltersBtn.addEventListener('click', () => {
        filtersPanel.classList.toggle('hidden');
        const isHidden = filtersPanel.classList.contains('hidden');
        if (filtersArrow) {
          filtersArrow.style.transform = isHidden ? 'rotate(0deg)' : 'rotate(180deg)';
        }
      });
    }

    if (refreshApiBtn) {
      refreshApiBtn.addEventListener('click', () => {
        if (!isRefreshing) refreshData(true);
      });
    }

    if (retryBtn) {
      retryBtn.addEventListener('click', () => {
        refreshData(true);
      });
    }

    // Filter controls
    if (searchInput) {
      searchInput.addEventListener('input', (e: any) => {
        const val = e.target.value;
        if (searchClearBtn) {
          searchClearBtn.style.display = val.trim() ? 'block' : 'none';
        }
        
        if (searchTimeout) clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => {
          currentFilters.search = val.toLowerCase().trim();
          invalidateFilterCache();
          renderFeed();
        }, 150);
      });
    }

    if (searchClearBtn && searchInput) {
      searchClearBtn.addEventListener('click', () => {
        searchInput.value = '';
        currentFilters.search = '';
        searchClearBtn.style.display = 'none';
        invalidateFilterCache();
        renderFeed();
      });
    }

    if (viewSelector) {
      viewSelector.addEventListener('change', (e: any) => {
        currentView = e.target.value;
        renderFeed();
      });
    }

    if (audioFilter) {
      audioFilter.addEventListener('change', (e: any) => {
        currentFilters.audio = e.target.value;
        invalidateFilterCache();
        renderFeed();
      });
    }

    if (subFilter) {
      subFilter.addEventListener('change', (e: any) => {
        currentFilters.sub = e.target.value;
        invalidateFilterCache();
        renderFeed();
      });
    }

    if (resetFiltersBtn) {
      resetFiltersBtn.addEventListener('click', () => {
        if (searchInput) searchInput.value = '';
        if (audioFilter) audioFilter.value = 'all';
        if (subFilter) subFilter.value = 'all';
        if (searchClearBtn) searchClearBtn.style.display = 'none';
        
        currentFilters = { search: '', audio: 'all', sub: 'all' };
        invalidateFilterCache();
        renderFeed();
      });
    }

    if (useProxyCheckbox) {
      useProxyCheckbox.addEventListener('change', (e: any) => {
        localStorage.setItem('cr_use_cors_proxy', String(e.target.checked));
        
        // Clear cache and reload
        allEpisodes = [];
        clearCache();
        
        fetchLanguages().then(() => {
          refreshData(true);
        });
      });
    }

    // Toast Click to Load
    if (newEpisodesToast) {
      newEpisodesToast.addEventListener('click', () => {
        if (pendingEpisodes) {
          allEpisodes = pendingEpisodes;
          saveEpisodesCache();
          updateTimestamp(new Date());
          
          pendingEpisodes = null;
          hideNewEpisodesToast();
          
          renderFeed();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      });
    }

    // Scroll Back to Top Auto Commit
    window.addEventListener('scroll', () => {
      if (window.scrollY < 100 && pendingEpisodes) {
        allEpisodes = pendingEpisodes;
        saveEpisodesCache();
        updateTimestamp(new Date());
        
        pendingEpisodes = null;
        hideNewEpisodesToast();
        
        renderFeed();
      }
    });
  }

  function setupFeedDelegation() {
    if (!episodesContainer) return;

    episodesContainer.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;

      const copyBtn = target.closest('.id-box') as HTMLElement | null;
      if (copyBtn && copyBtn.textContent) {
        e.stopPropagation();
        copyToClipboard(copyBtn.textContent.trim());
        return;
      }

      const watchLink = target.closest('[data-watch-id]') as HTMLElement | null;
      if (watchLink) {
        const episodeId = watchLink.getAttribute('data-watch-id');
        if (episodeId) handleWatchedToggle(episodeId);
      }
    });
  }

  function setImageSrc(img, src) {
    if (src) {
      img.src = src;
      img.classList.remove('img-placeholder');
    } else if (PLACEHOLDER_IMG) {
      img.src = PLACEHOLDER_IMG;
    } else {
      img.removeAttribute('src');
      img.classList.add('img-placeholder');
    }
  }

  // Access Token management helper
  async function getAccessToken() {
    if (currentAccessToken) return currentAccessToken;
    const token = await getAccessTokenApi();
    if (token) {
      currentAccessToken = token;
      return currentAccessToken;
    }
    return null;
  }

  // Load from LocalStorage
  function loadCachedData() {
    try {
      const cached = localStorage.getItem(CACHE_KEY);
      const cacheTime = localStorage.getItem(CACHE_TIME_KEY);
      
      if (cached) {
        allEpisodes = JSON.parse(cached);
        if (cacheTime) {
          updateTimestamp(new Date(parseInt(cacheTime, 10)));
        }
        
        hasMore = allEpisodes.length >= 60;
        if (hasMore && sentinel) {
          sentinel.classList.remove('hidden');
        } else if (sentinel) {
          sentinel.classList.add('hidden');
        }

        loadingState.classList.add('hidden');
        renderFeed();
      }
    } catch (e) {
      console.error('Error loading cached data:', e);
    }
  }

  // Fetch New Data via CORS Proxy
  async function refreshData(isManual = false) {
    if (isRefreshing || isLoadingMore) return;
    
    isRefreshing = true;
    toggleLoadingUI(true);

    try {
      if (isManual) {
        currentAccessToken = null; // force token refresh
      }

      const token = await getAccessToken();
      if (!token) {
        throw new Error("Could not acquire Crunchyroll token.");
      }

      // Fetch Latest Episodes (Page 1 - offset 0)
      const episodes = await fetchCrunchyrollEpisodes(token, 0);
      if (!episodes || episodes.length === 0) {
        throw new Error("No episodes returned from Crunchyroll.");
      }

      const formatted = episodes.map(ep => formatEpisode(ep));

      // Check if there are new episodes compared to our loaded feed
      const hasNewContent = allEpisodes.length === 0 || (formatted.length > 0 && formatted[0].id !== allEpisodes[0].id);

      if (hasNewContent) {
        if (!isManual && window.scrollY >= 100) {
          // User is scrolled down and new episodes were found in auto-polling:
          // Cache them in pendingEpisodes and notify the user (do not rewrite DOM)
          pendingEpisodes = formatted;
          showNewEpisodesToast();
        } else {
          // Normal update: Overwrite and render immediately
          allEpisodes = formatted;
          invalidateFilterCache();
          saveEpisodesCache();
          
          const now = Date.now();
          updateTimestamp(new Date(now));

          hasMore = episodes.length >= 60;
          if (hasMore && sentinel) {
            sentinel.classList.remove('hidden');
          } else if (sentinel) {
            sentinel.classList.add('hidden');
          }

          errorState.classList.add('hidden');
          loadingState.classList.add('hidden');
          
          // Hide notification toast
          hideNewEpisodesToast();
          pendingEpisodes = null;
          
          renderFeed();
        }
      } else {
        // NO NEW CONTENT: Just update cache timestamp to prevent polling again immediately, 
        // and update the update timestamp text, but do NOT call renderFeed() (avoids scroll jumps!)
        const now = Date.now();
        localStorage.setItem(CACHE_TIME_KEY, now.toString());
        updateTimestamp(new Date(now));

        errorState.classList.add('hidden');
        loadingState.classList.add('hidden');
      }
    } catch (err: any) {
      console.error('Refresh API failed:', err);
      if (allEpisodes.length === 0) {
        if (errorMessage) errorMessage.textContent = err.message || "Failed to load Crunchyroll data.";
        errorState.classList.remove('hidden');
        loadingState.classList.add('hidden');
        episodesContainer.classList.add('hidden');
      } else {
        showToast("Error updating releases. Showing cached data.");
      }
    } finally {
      isRefreshing = false;
      toggleLoadingUI(false);
    }
  }

  // Fetch next page (older episodes)
  async function loadNextPage() {
    if (isRefreshing || isLoadingMore || !hasMore) return;

    isLoadingMore = true;
    if (sentinel) sentinel.classList.remove('hidden');

    try {
      const token = await getAccessToken();
      if (!token) throw new Error("Could not acquire token.");

      const offset = allEpisodes.length;
      const episodes = await fetchCrunchyrollEpisodes(token, offset);
      
      if (!episodes || episodes.length === 0) {
        hasMore = false;
        if (sentinel) sentinel.classList.add('hidden');
        return;
      }

      const formatted = episodes.map(ep => formatEpisode(ep));
      allEpisodes = [...allEpisodes, ...formatted];
      invalidateFilterCache();
      saveEpisodesCache();

      hasMore = episodes.length >= 60;
      if (!hasMore && sentinel) {
        sentinel.classList.add('hidden');
      }

      renderFeed({ appendOnly: true, newEpisodes: formatted });
    } catch (err) {
      console.error("Failed to load older episodes:", err);
      showToast("Failed to load older episodes.");
    } finally {
      isLoadingMore = false;
    }
  }

  function toggleLoadingUI(isLoading) {
    if (refreshApiBtn) {
      (refreshApiBtn as HTMLButtonElement).disabled = isLoading;
      refreshApiBtn.textContent = isLoading ? "Refreshing..." : "Refresh API";
    }
  }

  function updateTimestamp(date) {
    if (lastUpdateTimeSpan) {
      const timeStr = date.toTimeString().split(' ')[0];
      lastUpdateTimeSpan.textContent = timeStr;
    }
  }

  // RSS fetch deleted

  // Format single episode object
  function formatEpisode(ep) {
    const meta = ep.episode_metadata || {};
    
    // Series Title
    let seriesTitle = meta.series_title || "Unknown Series";
    
    // Add season name if applicable
    if (meta.season_title && meta.season_title.startsWith("Season") && !meta.season_title.includes("Season 1")) {
      seriesTitle += ` ${meta.season_title}`;
    }

    // Audio Language
    const audioLocale = meta.audio_locale || "";
    
    // Subtitles list
    const subtitleLocales = meta.subtitle_locales || [];
    
    // Format duration
    let duration = "0s";
    if (meta.duration_ms) {
      const totalSecs = Math.floor(meta.duration_ms / 1000);
      const mins = Math.floor(totalSecs / 60);
      const secs = totalSecs % 60;
      duration = mins > 0 ? `${mins}m ${secs}s` : `${secs}s`;
    }

    // Best thumbnail resolution (optimal size around 600px width for fast loading)
    let thumbnail = "";
    if (ep.images && ep.images.thumbnail) {
      const thumbs = ep.images.thumbnail.flat();
      if (thumbs.length > 0) {
        // Sort descending by resolution size
        const sorted = thumbs.toSorted((a, b) => b.width * b.height - a.width * a.height);
        const optimal = sorted.find(p => p.width >= 480 && p.width <= 800) || sorted[0];
        thumbnail = optimal.source;
      }
    }

    // Best poster_tall resolution (used in series view to avoid extra API calls)
    let posterTall = "";
    if (ep.images && ep.images.poster_tall) {
      const posters = ep.images.poster_tall.flat();
      if (posters.length > 0) {
        const sorted = posters.toSorted((a, b) => b.width * b.height - a.width * a.height);
        const optimal = sorted.find(p => p.width >= 240 && p.width <= 480) || sorted[sorted.length - 1];
        posterTall = optimal.source;
      }
    }

    // Extract publisher ID deleted

    // Release date
    const releasedAt = meta.premium_available_date || meta.availability_starts || ep.last_public;

    return {
      id: ep.id,
      title: ep.title || `Episode ${meta.episode_number || meta.episode || '-'}`,
      seriesTitle,
      description: ep.description || "No description available.",
      thumbnail,
      posterTall,
      episodeNumber: meta.episode || String(meta.episode_number || '--'),
      duration,
      audioLocale,
      subtitles: subtitleLocales,
      seriesId: meta.series_id || "Unknown",
      seasonId: meta.season_id || "Unknown",
      episodeId: ep.id,
      releasedAt
    };
  }

  // Render Card Feed
  function renderFeed(options = {}) {
    if (!episodesContainer) return;

    const filtered = getFilteredEpisodes();
    const filterKey = filterCacheKey;

    if (options.appendOnly && filterKey === lastRenderedFilterKey && currentView === lastRenderedView) {
      const newEpisodes = (options.newEpisodes || []).filter(episodePassesFilter);
      if (newEpisodes.length > 0) {
        if (currentView === 'feed') {
          appendFeedCards(newEpisodes);
        } else if (currentView === 'compact') {
          appendCompactRows(newEpisodes);
        } else {
          renderFullFeed(filtered);
        }
        return;
      }
    }

    renderFullFeed(filtered);
  }

  function renderFullFeed(filtered) {
    // Handle Empty State
    if (filtered.length === 0) {
      emptyState.classList.remove('hidden');
      episodesContainer.classList.add('hidden');
      if (sentinel) sentinel.classList.add('hidden');
      renderedEpisodeIds.clear();
      return;
    }

    emptyState.classList.add('hidden');
    episodesContainer.classList.remove('hidden');
    if (hasMore && sentinel) sentinel.classList.remove('hidden');

    renderedEpisodeIds.clear();
    lastRenderedView = currentView;
    lastRenderedFilterKey = filterCacheKey;

    if (currentView === 'feed') {
      renderFeedCard(filtered);
    } else if (currentView === 'compact') {
      renderFeedCompact(filtered);
    } else if (currentView === 'series') {
      renderFeedSeries(filtered);
    } else if (currentView === 'schedule') {
      renderFeedSchedule(filtered);
    }
  }

  function getDateGroupKey(releasedAt) {
    const date = new Date(releasedAt);
    return date.toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' }).toUpperCase();
  }

  function findOrCreateDateSection(dateStr) {
    const sections = episodesContainer.querySelectorAll('.feed-section');
    for (const section of sections) {
      if (section.getAttribute('data-date') === dateStr) {
        return section.querySelector('.feed-grid');
      }
    }

    const groupSection = document.createElement('section');
    groupSection.className = 'feed-section flex flex-col gap-6';
    groupSection.setAttribute('data-date', dateStr);

    const headerWrapper = document.createElement('div');
    headerWrapper.className = 'flex items-center justify-center w-full relative my-4';

    const line = document.createElement('div');
    line.className = 'absolute left-0 right-0 h-px bg-white/5 z-0';
    headerWrapper.appendChild(line);

    const header = document.createElement('div');
    header.className = 'bg-bg-primary text-accent-orange text-xs font-extrabold tracking-widest px-6 py-1.5 border border-white/5 rounded-full z-10 uppercase';
    header.textContent = dateStr;
    headerWrapper.appendChild(header);
    groupSection.appendChild(headerWrapper);

    const grid = document.createElement('div');
    grid.className = 'feed-grid grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-4';
    groupSection.appendChild(grid);
    episodesContainer.appendChild(groupSection);

    return grid;
  }

  function appendFeedCards(newEpisodes) {
    const watchedId = localStorage.getItem(LAST_SEEN_KEY);

    newEpisodes.forEach(ep => {
      if (renderedEpisodeIds.has(ep.id)) return;
      renderedEpisodeIds.add(ep.id);

      const dateStr = getDateGroupKey(ep.releasedAt);
      const grid = findOrCreateDateSection(dateStr);
      const cardNode = createEpisodeCardNode(ep, watchedId);
      grid.appendChild(cardNode);
    });
  }

  function appendCompactRows(newEpisodes) {
    let listWrapper = episodesContainer.querySelector('.compact-list') as HTMLElement | null;
    if (!listWrapper) {
      listWrapper = document.createElement('div');
      listWrapper.className = 'compact-list flex flex-col gap-3 w-full';
      episodesContainer.appendChild(listWrapper);
    }

    const watchedId = localStorage.getItem(LAST_SEEN_KEY);
    const fragment = document.createDocumentFragment();

    newEpisodes.forEach(ep => {
      if (renderedEpisodeIds.has(ep.id)) return;
      renderedEpisodeIds.add(ep.id);
      fragment.appendChild(createCompactRow(ep, watchedId));
    });

    listWrapper.appendChild(fragment);
  }

  // 1. View Mode: Card Feed
  function renderFeedCard(filtered) {
    const groups = {};
