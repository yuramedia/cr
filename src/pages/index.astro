          onerror="this.src='${widePoster || posterUrl}'; this.onerror=null;"
        />
        
        <div class="flex flex-col md:flex-row gap-6 relative z-10">
          ${posterUrl ? `<img src="${posterUrl}" alt="${series.title}" class="w-32 h-auto rounded-lg border border-white/10 shadow-md self-start">` : ''}
          <div class="flex flex-col gap-3 justify-center">
            <h2 class="text-2xl sm:text-3xl font-extrabold text-text-primary leading-tight">${series.title}</h2>
            <p class="text-text-secondary text-sm max-w-4xl leading-relaxed font-sans">${series.description || 'No description available.'}</p>
          </div>
        </div>
      </div>

      <div class="seasons-container">
        <h3 class="text-lg font-bold text-text-primary mb-4 flex items-center gap-2">
          <span class="text-accent-orange">🎬</span> Seasons & Episodes
        </h3>
        ${seasonsHtml}
      </div>
    `;

    // Hook up accordion events
    const accordions = detailContent.querySelectorAll('.season-accordion');
    accordions.forEach(acc => {
      const header = acc.querySelector('button') as HTMLButtonElement;
      const body = acc.querySelector('.accordion-body') as HTMLElement;
      const arrow = acc.querySelector('.accordion-arrow') as HTMLElement;
      const seasonId = acc.getAttribute('data-season-id')!;

      header.addEventListener('click', async (e) => {
        e.stopPropagation();
        const isHidden = body.classList.contains('hidden');
        if (isHidden) {
          body.classList.remove('hidden');
          body.classList.add('border-t', 'border-white/5');
          arrow.classList.add('rotate-180');
          // If first time loading this accordion
          const loadBtn = body.querySelector('.load-season-episodes-btn') as HTMLButtonElement;
          if (loadBtn) {
            await loadAccordionEpisodes(body, seasonId, token);
          }
        } else {
          body.classList.add('hidden');
          body.classList.remove('border-t', 'border-white/5');
          arrow.classList.remove('rotate-180');
        }
      });
    });

    // Auto-load first accordion
    if (seasons && seasons.length > 0) {
      const firstBody = accordions[0].querySelector('.accordion-body') as HTMLElement;
      const firstSeasonId = seasons[0].id;
      await loadAccordionEpisodes(firstBody, firstSeasonId, token);
    }
  }

  // Load episodes of a specific accordion season
  async function loadAccordionEpisodes(body: HTMLElement, seasonId: string, token: string) {
    const loader = body.querySelector('.accordion-episodes-loading') || body.querySelector('.load-season-episodes-btn');
    const grid = body.querySelector('.accordion-episodes-grid') as HTMLElement;

    if (loader) {
      body.innerHTML = `
        <div class="accordion-episodes-loading flex justify-center py-8">
          <div class="animate-spin rounded-full h-8 w-8 border-3 border-t-accent-orange border-white/10"></div>
        </div>
        <div class="accordion-episodes-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 hidden"></div>
      `;
    }

    const finalGrid = body.querySelector('.accordion-episodes-grid') as HTMLElement;

    try {
      const episodes = await fetchSeasonEpisodes(seasonId, token);
      if (!episodes || episodes.length === 0) {
        body.innerHTML = `<p class="text-text-secondary text-sm py-4 text-center">No episodes found in this season.</p>`;
        return;
      }

      let html = '';
      episodes.forEach(ep => {
        const watchedKey = `cr_watched_${ep.id}`;
        const watchedVal = localStorage.getItem(watchedKey);
        const isWatched = watchedVal !== null;
        
        const epNum = ep.episode_number || ep.episode || '';
        const seriesTitle = ep.series_title || '';
        const sheetKey = `${normalizeTitleForSheet(seriesTitle)}_${epNum}`;
        const hasFormats = sheetDataMap.has(sheetKey);

        const thumb = ep.images?.thumbnail?.[0]?.[2]?.source || ep.images?.thumbnail?.[0]?.[0]?.source || '';

        const releaseDate = ep.premium_available_date || ep.availability_starts || ep.available_date;
        const releaseDateStr = releaseDate ? new Date(releaseDate).toLocaleDateString() : '-';

        html += `
          <a href="#/eps/${ep.id}" class="flex flex-col bg-[#16161e] border border-white/5 hover:border-accent-orange/30 rounded-xl overflow-hidden transition-all duration-300 group shadow-md hover:-translate-y-0.5 select-none">
            <div class="relative aspect-video overflow-hidden bg-[#0b0b0d]">
              ${thumb ? `<img src="${thumb}" alt="${ep.title}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">` : `<div class="w-full h-full bg-white/2 flex items-center justify-center"><span class="text-[0.65rem] font-bold text-text-muted">NO THUMBNAIL</span></div>`}
              ${isWatched ? `<span class="absolute top-2 right-2 bg-accent-orange text-white text-[0.6rem] font-bold px-2 py-0.5 rounded-full shadow">WATCHED</span>` : ''}
              ${hasFormats ? `<span class="absolute bottom-2 left-2 bg-bg-card/90 border border-white/5 text-accent-orange text-[0.6rem] font-extrabold px-2 py-0.5 rounded shadow flex items-center gap-1">📊 FORMATS</span>` : ''}
            </div>
            <div class="p-4 flex flex-col gap-1.5 flex-grow justify-between">
              <div>
                <span class="text-[0.65rem] font-bold text-accent-orange tracking-wider uppercase">Episode ${epNum || '-'}</span>
                <h4 class="text-sm font-extrabold text-text-primary line-clamp-1 group-hover:text-accent-orange transition-colors mt-0.5">${ep.title || 'Untitled'}</h4>
              </div>
              <span class="text-[0.625rem] text-text-secondary font-medium">Release: ${releaseDateStr}</span>
            </div>
          </a>
        `;
      });

      const loadingSpinner = body.querySelector('.accordion-episodes-loading') as HTMLElement;
      if (loadingSpinner) loadingSpinner.classList.add('hidden');
      finalGrid.innerHTML = html;
      finalGrid.classList.remove('hidden');
    } catch (e) {
      console.error(e);
      body.innerHTML = `<p class="text-accent-red text-sm py-4 text-center">Failed to load episodes: ${e instanceof Error ? e.message : 'Unknown error'}</p>`;
    }
  }

  // Render Season Detail Page
  async function renderSeasonDetail(seasonId: string, token: string) {
    const detailLoader = document.getElementById('detail-loader') as HTMLElement;
    const detailContent = document.getElementById('detail-content') as HTMLElement;

    // Fetch season details
    const season = await fetchObject(seasonId, token);
    if (!season) {
      throw new Error(`Season with ID ${seasonId} not found.`);
    }

    const episodes = await fetchSeasonEpisodes(seasonId, token);

    detailLoader.classList.add('hidden');
    detailContent.classList.remove('hidden');

    let episodesHtml = '';
    if (episodes && episodes.length > 0) {
      episodes.forEach(ep => {
        const watchedKey = `cr_watched_${ep.id}`;
        const watchedVal = localStorage.getItem(watchedKey);
        const isWatched = watchedVal !== null;
        
        const epNum = ep.episode_number || ep.episode || '';
        const seriesTitle = ep.series_title || '';
        const sheetKey = `${normalizeTitleForSheet(seriesTitle)}_${epNum}`;
        const hasFormats = sheetDataMap.has(sheetKey);

        const thumb = ep.images?.thumbnail?.[0]?.[2]?.source || ep.images?.thumbnail?.[0]?.[0]?.source || '';

        const releaseDate = ep.premium_available_date || ep.availability_starts || ep.available_date;
        const releaseDateStr = releaseDate ? new Date(releaseDate).toLocaleDateString() : '-';

        episodesHtml += `
          <a href="#/eps/${ep.id}" class="flex flex-col bg-[#16161e] border border-white/5 hover:border-accent-orange/30 rounded-xl overflow-hidden transition-all duration-300 group shadow-md hover:-translate-y-0.5 select-none">
            <div class="relative aspect-video overflow-hidden bg-[#0b0b0d]">
              ${thumb ? `<img src="${thumb}" alt="${ep.title}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">` : `<div class="w-full h-full bg-white/2 flex items-center justify-center"><span class="text-[0.65rem] font-bold text-text-muted">NO THUMBNAIL</span></div>`}
              ${isWatched ? `<span class="absolute top-2 right-2 bg-accent-orange text-white text-[0.6rem] font-bold px-2 py-0.5 rounded-full shadow">WATCHED</span>` : ''}
              ${hasFormats ? `<span class="absolute bottom-2 left-2 bg-bg-card/90 border border-white/5 text-accent-orange text-[0.6rem] font-extrabold px-2 py-0.5 rounded shadow flex items-center gap-1">📊 FORMATS</span>` : ''}
            </div>
            <div class="p-4 flex flex-col gap-1.5 flex-grow justify-between">
              <div>
                <span class="text-[0.65rem] font-bold text-accent-orange tracking-wider uppercase">Episode ${epNum || '-'}</span>
                <h4 class="text-sm font-extrabold text-text-primary line-clamp-1 group-hover:text-accent-orange transition-colors mt-0.5">${ep.title || 'Untitled'}</h4>
              </div>
              <span class="text-[0.625rem] text-text-secondary font-medium">Release: ${releaseDateStr}</span>
            </div>
          </a>
        `;
      });
    } else {
      episodesHtml = `<div class="col-span-full text-center py-10 bg-bg-card border border-white/5 rounded-xl"><p class="text-text-secondary text-sm">No episodes found in this season.</p></div>`;
    }

    detailContent.innerHTML = `
      <div class="bg-bg-card border border-white/5 rounded-2xl p-6 sm:p-8 shadow-2xl">
        <div class="flex items-center gap-2 text-[0.675rem] font-bold uppercase tracking-wider text-text-muted mb-6">
          <a href="#/" class="hover:text-accent-orange transition-colors">Home</a>
          <span>/</span>
          <a href="#/series/${season.season_metadata?.series_id}" class="hover:text-accent-orange transition-colors">Series Detail</a>
          <span>/</span>
          <span class="text-text-secondary">${season.title || 'Season'}</span>
        </div>

        <h2 class="text-2xl sm:text-3xl font-extrabold text-text-primary leading-tight mb-6">${season.title || 'Season Episodes'}</h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          ${episodesHtml}
        </div>
      </div>
    `;
  }
</script>
