            const img = document.createElement('img');
            setImageSrc(img, show.thumbnail);
            img.className = 'w-full h-full object-cover';
            img.loading = 'lazy';
            img.decoding = 'async';
            
            const thumbLink = document.createElement('a');
            thumbLink.href = `#/series/${show.eps[0].seriesId}`;
            thumbLink.appendChild(img);
            thumbWrapper.appendChild(thumbLink);
            item.appendChild(thumbWrapper);
          }

          const timeStr = document.createElement('div');
          timeStr.className = 'text-accent-orange font-bold text-[0.65rem]';
          timeStr.textContent = show.time;
          item.appendChild(timeStr);

          const title = document.createElement('div');
          title.className = 'text-white font-semibold truncate';
          const titleLink = document.createElement('a');
          titleLink.href = `#/series/${show.eps[0].seriesId}`;
          titleLink.className = 'hover:text-accent-orange-hover hover:underline transition-colors';
          titleLink.textContent = show.seriesTitle;
          title.appendChild(titleLink);
          item.appendChild(title);

          const audiosRow = document.createElement('div');
          audiosRow.className = 'flex gap-1 flex-wrap mt-0.5';
          show.eps.forEach(ep => {
