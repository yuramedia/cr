  // Create DOM Node from Template
  function createEpisodeCardNode(ep, watchedId) {
    const clone = cardTemplate.content.cloneNode(true) as DocumentFragment;
    const card = clone.querySelector('.episode-card') as HTMLElement;
    card.setAttribute('data-episode-id', ep.id);
    card.setAttribute('data-series-title', ep.seriesTitle);
    card.setAttribute('data-episode-number', String(ep.episodeNumber));
    
    const img = card.querySelector('.card-image') as HTMLImageElement;
    setImageSrc(img, ep.thumbnail);
    img.alt = ep.seriesTitle;

    // Wrap the image in a link to the episode detail page
    const imgContainer = img.parentElement as HTMLElement;
    if (imgContainer) {
      const link = document.createElement('a');
      link.href = `#/eps/${ep.id}`;
      link.className = 'block w-full h-full';
      img.parentNode?.insertBefore(link, img);
      link.appendChild(img);
    }

    const badge = card.querySelector('.episode-badge') as HTMLElement;
    if (badge) {
      badge.textContent = `EPISODE ${ep.episodeNumber}`;
    }

    const seriesTitleEl = card.querySelector('.series-title') as HTMLElement;
    seriesTitleEl.innerHTML = `<a href="#/series/${ep.seriesId}" class="hover:text-accent-orange-hover hover:underline transition-colors">${ep.seriesTitle}</a>`;
    
    const epTitle = card.querySelector('.episode-title') as HTMLElement;
    epTitle.innerHTML = `<a href="#/eps/${ep.id}" class="hover:text-accent-orange-hover transition-colors">${ep.title}</a>`;
    epTitle.title = ep.title;

    const desc = card.querySelector('.episode-description') as HTMLElement;
    desc.textContent = ep.description;
    desc.title = ep.description;

    const date = new Date(ep.releasedAt);
    const dateFormatted = date.toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' }) + `, ` + date.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false });
    card.querySelector('.val-release').textContent = dateFormatted;

    const audioLabel = ep.audioLocale ? (activeLangMap[ep.audioLocale] || ep.audioLocale) : '-';
    const audioSpan = document.createElement('span');
    audioSpan.className = 'bg-accent-orange/12 border border-accent-orange/20 text-accent-orange px-1.5 py-0.5 rounded font-bold text-[0.725rem]';
    audioSpan.textContent = audioLabel;
    card.querySelector('.val-audio').appendChild(audioSpan);

    const subsContainer = card.querySelector('.val-subs') as HTMLElement;
    if (ep.subtitles && ep.subtitles.length > 0) {
      const limit = 3;
      const showCollapse = ep.subtitles.length > limit;

      ep.subtitles.forEach((sub, idx) => {
        const cleanName = activeLangMap[sub] || sub;
        const subItem = document.createElement('bidi-item');
        subItem.textContent = cleanName;
        if (showCollapse && idx >= (limit - 1)) {
          subItem.classList.add('extra-sub');
          subItem.style.display = 'none';
        }
        subsContainer.appendChild(subItem);
      });

      if (showCollapse) {
        const moreBtn = document.createElement('button');
        moreBtn.className = 'text-accent-orange font-extrabold cursor-pointer hover:text-white transition-colors duration-200 select-none bg-accent-orange/10 border border-accent-orange/20 px-2 py-0.5 rounded hover:bg-accent-orange/20 text-[0.65rem] uppercase font-sans shrink-0';
        moreBtn.textContent = `+${ep.subtitles.length - (limit - 1)} more`;
        moreBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          card.querySelectorAll('.extra-sub').forEach(el => {
            (el as HTMLElement).style.display = '';
          });
          moreBtn.remove();
        });
        subsContainer.appendChild(moreBtn);
      }
    } else {
      subsContainer.textContent = '-';
    }

    card.querySelector('.val-series-id').textContent = ep.seriesId;
    card.querySelector('.val-season-id').textContent = ep.seasonId;
    card.querySelector('.val-episode-id').textContent = ep.episodeId;

    const actionBtn = card.querySelector('.seen-action-btn') as HTMLAnchorElement;
    actionBtn.href = `https://www.crunchyroll.com/watch/${ep.id}`;
    actionBtn.setAttribute('data-watch-id', ep.id);
    
    if (watchedId === ep.id) {
      card.classList.add('watched');
      actionBtn.textContent = 'Watch Episode (Last Seen)';
    } else {
      actionBtn.textContent = 'Watch Episode';
    }

    populatePipelineForCard(card, ep.seriesTitle, ep.episodeNumber);
    return card;
  }

  // Copy Clipboard Helper
  function copyToClipboard(text) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(text).then(() => {
        showToast(`Copied ID: ${text}`);
      }).catch(err => {
        console.error('Clipboard copy failed:', err);
      });
    } else {
      // Fallback
      const textArea = document.createElement("textarea");
      textArea.value = text;
      textArea.style.position = "fixed";
      document.body.appendChild(textArea);
      textArea.focus();
      textArea.select();
      try {
        document.execCommand('copy');
        showToast(`Copied ID: ${text}`);
      } catch (err) {
        console.error('Fallback copy failed:', err);
      }
      document.body.removeChild(textArea);
    }
  }

  // Show Toast Alert
  function showToast(message) {
    if (copiedToast && toastText) {
      toastText.textContent = ` ${message}`;
      copiedToast.classList.add('show');
      setTimeout(() => {
        copiedToast.classList.remove('show');
      }, 2500);
    }
  }

  // Handle Mark as Last Seen Click
  function handleWatchedToggle(episodeId) {
    const currentWatched = localStorage.getItem(LAST_SEEN_KEY);
    
    if (currentWatched === episodeId) {
      localStorage.removeItem(LAST_SEEN_KEY);
      updateWatchedState(currentWatched, null);
    } else {
      localStorage.setItem(LAST_SEEN_KEY, episodeId);
      updateWatchedState(currentWatched, episodeId);
    }
  }

  function updateWatchedState(oldId, newId) {
    if (oldId) {
      document.querySelectorAll(`[data-episode-id="${oldId}"]`).forEach(el => {
        el.classList.remove('watched', 'border-accent-blue/30', 'bg-accent-blue/3', 'bg-accent-blue/5', 'shadow-[0_0_15px_rgba(0,132,255,0.1)]');
        const btn = el.querySelector('.seen-action-btn') as HTMLElement | null;
        if (btn) btn.textContent = 'Watch Episode';
      });
      document.querySelectorAll(`[data-watch-id="${oldId}"]`).forEach(el => {
        if (!el.classList.contains('seen-action-btn')) {
          el.className = 'text-[0.55rem] font-bold bg-white/5 border border-white/10 px-1 py-0.2 rounded hover:bg-accent-orange/10 hover:border-accent-orange/30 text-text-secondary hover:text-accent-orange transition-colors';
        }
      });
    }

    if (newId) {
      document.querySelectorAll(`[data-episode-id="${newId}"]`).forEach(el => {
        if (el.classList.contains('episode-card')) {
          el.classList.add('watched');
          const btn = el.querySelector('.seen-action-btn') as HTMLElement | null;
          if (btn) btn.textContent = 'Watch Episode (Last Seen)';
        } else if (el.classList.contains('compact-row')) {
          el.classList.add('border-accent-blue/30', 'bg-accent-blue/3');
        } else {
          el.classList.add('border-accent-blue/30', 'bg-accent-blue/5');
          const card = el.closest('.series-card');
          if (card) card.classList.add('border-accent-blue/30', 'shadow-[0_0_15px_rgba(0,132,255,0.1)]');
        }
      });
      document.querySelectorAll(`[data-watch-id="${newId}"]`).forEach(el => {
        if (!el.classList.contains('seen-action-btn')) {
          el.className = 'text-[0.55rem] font-bold bg-accent-blue/10 border border-accent-blue/30 px-1 py-0.2 rounded text-accent-blue';
          const item = el.closest('[data-episode-id]');
          if (item) item.classList.add('border-accent-blue/30', 'bg-accent-blue/3');
        }
      });
    }
  }

  // Routing Handler
  async function handleRoute() {
    const hash = window.location.hash;
    const detailContainer = document.getElementById('detail-container') as HTMLElement;
    const detailLoader = document.getElementById('detail-loader') as HTMLElement;
    const detailContent = document.getElementById('detail-content') as HTMLElement;
    
    const episodesContainer = document.getElementById('episodes-container') as HTMLElement;
    const infiniteScrollSentinel = document.getElementById('infinite-scroll-sentinel') as HTMLElement;
    const filtersPanel = document.getElementById('filters-panel') as HTMLElement;
    const toggleFiltersBtn = document.getElementById('toggle-filters-btn') as HTMLElement;
    const viewSelector = document.getElementById('view-selector') as HTMLElement;
    const refreshApiBtn = document.getElementById('refresh-api-btn') as HTMLElement;
    const loadingState = document.getElementById('loading-state') as HTMLElement;
    const errorState = document.getElementById('error-state') as HTMLElement;
    const emptyState = document.getElementById('empty-state') as HTMLElement;

    if (!hash || hash === '#/' || hash === '') {
      // Main Feed Route
      if (detailContainer) detailContainer.classList.add('hidden');
      if (episodesContainer) episodesContainer.classList.remove('hidden');
      if (hasMore && sentinel) {
        infiniteScrollSentinel.classList.remove('hidden');
      }
      
      // Restore header controls
      if (toggleFiltersBtn) toggleFiltersBtn.style.display = '';
      if (viewSelector) viewSelector.style.display = '';
      if (refreshApiBtn) refreshApiBtn.style.display = '';
      
      // Re-trigger rendering to ensure correct state
      renderFeed();
      return;
    }

    // Detail Page Routes
    // Hide main feed UI elements
    if (episodesContainer) episodesContainer.classList.add('hidden');
    if (infiniteScrollSentinel) infiniteScrollSentinel.classList.add('hidden');
    if (loadingState) loadingState.classList.add('hidden');
    if (errorState) errorState.classList.add('hidden');
    if (emptyState) emptyState.classList.add('hidden');
    if (filtersPanel) filtersPanel.classList.add('hidden');
    
    // Hide header controls
    if (toggleFiltersBtn) toggleFiltersBtn.style.display = 'none';
    if (viewSelector) viewSelector.style.display = 'none';
    if (refreshApiBtn) refreshApiBtn.style.display = 'none';

    // Show detail panel & loader
    if (detailContainer) detailContainer.classList.remove('hidden');
    if (detailLoader) detailLoader.classList.remove('hidden');
    if (detailContent) {
      detailContent.classList.add('hidden');
      detailContent.innerHTML = '';
    }

    const token = await getAccessToken();
    if (!token) {
      if (detailLoader) detailLoader.classList.add('hidden');
      if (detailContent) {
        detailContent.classList.remove('hidden');
        detailContent.innerHTML = `
          <div class="text-center py-10 bg-bg-card border border-white/5 rounded-xl">
            <p class="text-accent-red font-bold text-lg mb-2">Error</p>
            <p class="text-text-secondary">Failed to acquire access token. Please check your connection or CORS proxy settings.</p>
          </div>
        `;
      }
      return;
    }

    // Parse route
    const seriesMatch = hash.match(/^#\/series\/([a-zA-Z0-9]+)$/);
    const seasonMatch = hash.match(/^#\/season\/([a-zA-Z0-9]+)$/);
    const episodeMatch = hash.match(/^#\/eps\/([a-zA-Z0-9]+)$/) || hash.match(/^#\/episode\/([a-zA-Z0-9]+)$/);

    try {
      if (seriesMatch) {
        const seriesId = seriesMatch[1];
        await renderSeriesDetail(seriesId, token);
      } else if (seasonMatch) {
        const seasonId = seasonMatch[1];
        await renderSeasonDetail(seasonId, token);
      } else if (episodeMatch) {
        const episodeId = episodeMatch[1];
        await renderEpisodeDetail(episodeId, token);
      } else {
        // Unknown route
        if (detailLoader) detailLoader.classList.add('hidden');
        if (detailContent) {
          detailContent.classList.remove('hidden');
          detailContent.innerHTML = `
            <div class="text-center py-10 bg-bg-card border border-white/5 rounded-xl">
              <p class="text-accent-red font-bold text-lg mb-2">Page Not Found</p>
              <p class="text-text-secondary">The requested page does not exist or has moved.</p>
            </div>
          `;
        }
      }
    } catch (e) {
      console.error("Error rendering detail page:", e);
      if (detailLoader) detailLoader.classList.add('hidden');
      if (detailContent) {
        detailContent.classList.remove('hidden');
        detailContent.innerHTML = `
          <div class="text-center py-10 bg-bg-card border border-white/5 rounded-xl">
            <p class="text-accent-red font-bold text-lg mb-2">Error</p>
            <p class="text-text-secondary">Failed to load content: ${e instanceof Error ? e.message : 'Unknown error'}</p>
          </div>
        `;
      }
    }
  }

