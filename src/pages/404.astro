---
// src/pages/404.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Redirecting... - Crunchyroll Tracker">
  <div class="flex flex-col items-center justify-center min-h-screen bg-[#0b0b0d] text-white p-6">
    <div class="border-3 border-white/5 border-t-[#ff6200] rounded-full w-12 h-12 animate-spin mb-6"></div>
    <p class="text-[#a0a0ab] text-lg font-medium">Loading page...</p>
  </div>

  <script is:inline>
    const path = window.location.pathname;
    // Strip trailing slashes and split
    const parts = path.split('/').filter(Boolean);
    if (parts.length >= 2) {
      const type = parts[0];
      const id = parts[1];
      if (type === 'eps' || type === 'series' || type === 'season') {
        window.location.replace('/#/' + type + '/' + id);
      } else {
        window.location.replace('/');
      }
    } else {
      window.location.replace('/');
    }
  </script>
</Layout>
