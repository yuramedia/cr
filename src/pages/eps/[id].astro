---
// src/pages/eps/[id].astro
import Layout from '../../layouts/Layout.astro';
import { getAccessToken, fetchCrunchyrollEpisodes } from '../../scripts/api';

export async function getStaticPaths() {
  const token = await getAccessToken();
  if (!token) return [];

  // Fetch recent releases (first 60 episodes)
  const episodes = await fetchCrunchyrollEpisodes(token, 0) || [];
  
  return episodes.map(ep => {
    // Select thumbnail source
    const thumbUrl = ep.images?.thumbnail?.[0]?.[0]?.source || '';
    
    return {
      params: { id: ep.id },
      props: {
        title: `${ep.title} - ${ep.episode_metadata?.series_title || 'Crunchyroll Tracker'}`,
        description: ep.description || `Watch episode ${ep.episode_metadata?.episode_number} of ${ep.episode_metadata?.series_title} on Crunchyroll Tracker.`,
        image: thumbUrl,
        url: `https://cr.yuramedia.com/eps/${ep.id}`
      }
    };
  });
}

const { id } = Astro.params;
const { title, description, image, url } = Astro.props;
---

<Layout title={title} description={description} image={image} url={url}>
  <div class="flex flex-col items-center justify-center min-h-screen bg-[#0b0b0d] text-white p-6">
    <div class="border-3 border-white/5 border-t-[#ff6200] rounded-full w-12 h-12 animate-spin mb-6"></div>
    <p class="text-[#a0a0ab] text-lg font-medium">Redirecting to episode detail page...</p>
  </div>

  <script is:inline define:vars={{ id }}>
    // Immediate client-side redirect to the SPA hash route
    window.location.replace('/#/eps/' + id);
  </script>
</Layout>
