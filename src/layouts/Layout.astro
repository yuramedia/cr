---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = "Crunchyroll Tracker" } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- SEO Embed Metadata -->
		<meta name="description" content="Track real-time Crunchyroll episode releases, view weekly broadcast schedules, filter audio/subtitles, and manage your watch history with a sleek, compact interface." />
		<meta name="theme-color" content="#ff6200" />
		<meta name="robots" content="index, follow" />

		<!-- Open Graph / Facebook / Discord Embeds -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content="Crunchyroll Tracker - Real-time Releases & Schedule" />
		<meta property="og:description" content="Track real-time Crunchyroll episode releases, view weekly broadcast schedules, filter audio/subtitles, and manage your watch history with a sleek, compact interface." />
		<meta property="og:url" content="https://cr.yuramedia.com/" />
		<meta property="og:site_name" content="Crunchyroll Tracker" />
		<meta property="og:image" content="https://cr.yuramedia.com/favicon.svg" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<!-- Twitter Card Embeds -->
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content="Crunchyroll Tracker - Real-time Releases & Schedule" />
		<meta name="twitter:description" content="Track real-time Crunchyroll episode releases, view weekly broadcast schedules, filter audio/subtitles, and manage your watch history with a sleek, compact interface." />
		<meta name="twitter:image" content="https://cr.yuramedia.com/favicon.svg" />

		<!-- JSON-LD Structured Data for Search Engine Embedding -->
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "WebApplication",
				"name": "Crunchyroll Tracker",
				"url": "https://cr.yuramedia.com/",
				"description": "Track real-time Crunchyroll episode releases, view weekly broadcast schedules, filter audio/subtitles, and manage your watch history.",
				"applicationCategory": "EntertainmentApplication",
				"operatingSystem": "All",
				"browserRequirements": "Requires JavaScript",
				"genre": "Anime"
			}
		</script>
	</head>
	<body>
		<slot />
	</body>
</html>
