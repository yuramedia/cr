---
// EpisodeCard.astro
---
<template id="episode-card-template">
  <article class="episode-card group bg-bg-card border border-white/5 rounded-xl flex flex-col overflow-hidden relative transition-all duration-300 hover:-translate-y-1 hover:border-white/10 hover:shadow-2xl" data-episode-id="">
    <div class="relative w-full aspect-video bg-[#0b0b0d] overflow-hidden">
      <img class="card-image w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 img-placeholder" src="" alt="Episode Thumbnail" loading="lazy" decoding="async" />
      <span class="episode-badge bg-accent-orange text-white text-[0.7rem] font-extrabold tracking-wider px-2.5 py-1.5 rounded absolute top-3 left-3 uppercase shadow-md">EPISODE --</span>
    </div>
    
    <div class="flex flex-col flex-grow p-4">
      <div class="series-title text-accent-orange text-[0.7rem] font-extrabold uppercase tracking-wider mb-1 truncate">Series Title</div>
      <h3 class="episode-title text-white text-[0.95rem] font-bold leading-snug mb-2 line-clamp-2">Episode Title</h3>
      <p class="episode-description text-text-secondary text-[0.75rem] leading-normal mb-4 line-clamp-3">Description text goes here...</p>
      
      <!-- mt-auto pushes this section to the bottom, aligning metadata across all cards -->
      <div class="flex flex-col gap-1.5 border-t border-white/5 pt-2 mb-4 mt-auto">
        <div class="flex text-[0.725rem]">
          <span class="text-text-muted font-semibold w-14 shrink-0">Release:</span>
          <span class="meta-value val-release text-white">Date here</span>
        </div>
        <div class="flex text-[0.725rem]">
          <span class="text-text-muted font-semibold w-14 shrink-0">Audio:</span>
          <span class="meta-value val-audio text-white"></span>
        </div>
        <div class="flex text-[0.725rem]">
          <span class="text-text-muted font-semibold w-14 shrink-0">Subtitles:</span>
          <div class="meta-value val-subs bidi-list">
            <!-- Subtitle badges injected here -->
          </div>
        </div>
      </div>

      <div class="flex flex-col gap-1 bg-[#0b0b0d] p-2 rounded-lg border border-white/3 mb-4">
        <div class="flex justify-between items-center text-[0.625rem]">
          <span class="text-text-muted font-bold">SERIES ID</span>
          <button class="id-box val-series-id bg-[#1c1c24] border border-white/5 text-text-secondary font-mono text-[0.65rem] px-1.5 py-0.5 rounded cursor-pointer transition-all duration-200 max-w-[120px] truncate hover:bg-[#272733] hover:text-white hover:border-white/15" title="Click to copy">------</button>
        </div>
        <div class="flex justify-between items-center text-[0.625rem]">
          <span class="text-text-muted font-bold">SEASON ID</span>
          <button class="id-box val-season-id bg-[#1c1c24] border border-white/5 text-text-secondary font-mono text-[0.65rem] px-1.5 py-0.5 rounded cursor-pointer transition-all duration-200 max-w-[140px] truncate hover:bg-[#272733] hover:text-white hover:border-white/15" title="Click to copy">------</button>
        </div>
        <div class="flex justify-between items-center text-[0.625rem]">
          <span class="text-text-muted font-bold">EPISODE ID</span>
          <button class="id-box val-episode-id bg-[#1c1c24] border border-white/5 text-text-secondary font-mono text-[0.65rem] px-1.5 py-0.5 rounded cursor-pointer transition-all duration-200 max-w-[140px] truncate hover:bg-[#272733] hover:text-white hover:border-white/15" title="Click to copy">------</button>
        </div>
      </div>

      <!-- Subtitle Pipeline Formats Container (Hidden by default, shown if spreadsheet matches) -->
      <div class="sub-pipeline-container flex flex-col hidden mb-4 text-[0.7rem] border-t border-white/5 pt-2 select-none">
        <button class="toggle-pipeline-btn text-text-muted hover:text-white font-bold flex items-center justify-between w-full select-none cursor-pointer">
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-accent-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Subtitle Formatting
          </span>
          <svg class="pipeline-arrow w-3 h-3 transition-transform duration-300 transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        
        <div class="pipeline-details hidden flex flex-col gap-1.5 mt-2 bg-[#0b0b0d] p-2 rounded border border-white/3">
          <div class="pipeline-grid grid grid-cols-2 gap-x-3 gap-y-1.5 text-[0.625rem]">
            <!-- Injected dynamically -->
          </div>
          <div class="pipeline-notes text-[0.625rem] text-text-muted border-t border-white/5 pt-1.5 mt-1.5 hidden font-sans leading-normal">
            <!-- Notes injected here -->
          </div>
        </div>
      </div>
      
      <a class="seen-action-btn flex items-center justify-center bg-transparent border border-white/10 text-white font-bold text-[0.75rem] py-2 rounded-lg transition-all duration-300 w-full hover:bg-white/4 hover:border-white/15" target="_blank" rel="noopener noreferrer">Watch Episode</a>
    </div>
  </article>
</template>
