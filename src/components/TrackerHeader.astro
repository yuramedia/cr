---
// TrackerHeader.astro
---
<header class="bg-bg-card border-b border-border-card flex flex-col md:flex-row justify-between items-center px-4 sm:px-6 md:px-8 py-3 md:py-4 gap-3 md:gap-4">
  <div class="header-left w-full md:w-auto text-center md:text-left flex flex-col sm:flex-row sm:items-center sm:justify-center md:justify-start gap-1 sm:gap-3">
    <h1 class="text-accent-orange text-2xl font-extrabold tracking-tight leading-none">Crunchyroll Tracker</h1>
    <span class="text-text-secondary text-[0.75rem] font-semibold self-center mt-1 sm:mt-0 opacity-80">
      LAST UPDATE: <span id="last-update-time" class="text-text-primary tabular-nums font-bold">--:--:--</span>
    </span>
  </div>
  <div class="flex flex-wrap items-center justify-center md:justify-end gap-3 w-full md:w-auto">
    <div class="flex items-center gap-2 flex-wrap justify-center w-full sm:w-auto">
      <button id="toggle-filters-btn" class="bg-[#1c1c24] border border-white/5 text-text-primary cursor-pointer text-xs sm:text-sm font-semibold rounded-lg px-3 sm:px-4 py-2 flex items-center gap-1.5 hover:bg-[#272733] hover:border-white/10 transition-colors duration-200" aria-label="Toggle Filters">
        Filters <span id="filters-arrow" class="text-[0.6rem] text-text-secondary transition-transform duration-200">▼</span>
      </button>
      
      <select id="view-selector" class="bg-[#1c1c24] border border-white/5 text-text-primary cursor-pointer text-xs sm:text-sm font-semibold rounded-lg px-3 sm:px-4 py-2 outline-none hover:bg-[#272733] hover:border-white/10 transition-colors duration-200" aria-label="Change View Mode">
        <option value="feed">View: Card Feed</option>
        <option value="compact">View: Compact List</option>
        <option value="series">View: Grouped by Title</option>
        <option value="schedule">View: Weekly Schedule</option>
      </select>
      
      <button id="refresh-api-btn" class="bg-accent-orange hover:bg-accent-orange-hover border-none text-white cursor-pointer text-xs sm:text-sm font-semibold rounded-lg px-3 sm:px-4 py-2 flex items-center gap-1.5 glowing-button transition-colors duration-200" aria-label="Refresh API">
        Refresh API
      </button>
    </div>
  </div>
</header>
